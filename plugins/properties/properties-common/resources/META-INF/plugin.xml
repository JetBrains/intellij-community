<idea-plugin package="com.intellij.lang.properties" allow-bundled-update="true">
  <id>com.intellij.properties</id>
  <name>Properties</name>
  <category>Languages</category>
  <description>
    Enables smart editing of .properties files.
  </description>
  <vendor>JetBrains</vendor>
  <resource-bundle>messages.PropertiesBundle</resource-bundle>

  <content namespace="jetbrains">
    <module name="intellij.properties.copyright"/>
    <module name="intellij.properties.backend.psi" required-if-available="intellij.platform.backend"/>
    <module name="intellij.properties.backend" required-if-available="intellij.platform.backend"/>
    <module name="intellij.properties" loading="embedded"/>
    <module name="intellij.properties.psi" loading="embedded"/>
  </content>
</idea-plugin>
