<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.gradle.java"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.properties.backend.psi"/>
    <module name="intellij.properties.psi"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <referencesSearch implementation="com.intellij.gradle.java.properties.findUsages.GradlePropertyReferencesSearcher"/>
    <properties.implicitPropertyUsageProvider implementation="com.intellij.gradle.java.properties.findUsages.GradleImplicitPropertyUsageProvider"/>

    <localInspection language="Properties" groupPath="Gradle" shortName="LatestMinorVersion"
                     bundle="messages.GradleInspectionBundle"
                     key="inspection.display.name.latest.minor.version" groupKey="inspection.best.practices"
                     groupBundle="messages.GradleInspectionBundle"
                     enabledByDefault="true" level="WARNING"
                     implementationClass="org.jetbrains.plugins.gradle.codeInspection.GradleLatestMinorVersionInspection"
                     isInternal="false"/>
  </extensions>
</idea-plugin>