<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.gradle"/>
    <module name="intellij.gradle.completion"/>
    <module name="intellij.repository.search.completion"/>
    <module name="intellij.toml.core"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <completion.contributor language="TOML"
                            id="KotlinGradleTomlCompletionContributor"
                            implementationClass="com.intellij.gradle.completion.toml.GradleTomlCompletionContributor"/>
    <statistics.collectorExtension implementation="com.intellij.gradle.completion.toml.GradleTomlCompletionUsageCollectorExtension"/>
    <lookup.usageDetails implementation="com.intellij.gradle.completion.toml.GradleTomlCompletionUsageDescriptor"/>
    <typedHandler implementation="com.intellij.gradle.completion.toml.GradleTomlDependenciesAutoPopupHandler"
                  id="GradleTomlDependenciesAutoPopupHandler"/>
  </extensions>
</idea-plugin>
