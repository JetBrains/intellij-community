<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.gradle"/>
    <module name="intellij.repository.search.completion"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <applicationService
      serviceInterface="com.intellij.gradle.completion.indexer.GradleLocalRepositoryIndexer"
      serviceImplementation="com.intellij.gradle.completion.indexer.GradleLocalRepositoryIndexerImpl"
      testServiceImplementation="com.intellij.gradle.completion.indexer.GradleLocalRepositoryIndexerTestImpl"/>
    <backgroundPostStartupActivity
      implementation="com.intellij.gradle.completion.indexer.GradleLocalRepositoryIndexInitializer"/>
    <externalSystemTaskNotificationListener
      implementation="com.intellij.gradle.completion.indexer.GradleLocalRepositoryIndexUpdater"/>
    <lookup.charFilter id="GradleCompletionCharFilter" order="first" implementation="com.intellij.gradle.completion.GradleCompletionCharFilter" />
    <statistics.collectorExtension implementation="com.intellij.gradle.completion.GradleScriptDependencyCompletionUsageCollectorExtension"/>
    <lookup.usageDetails implementation="com.intellij.gradle.completion.GradleScriptDependencyCompletionUsageDescriptor"/>

    <registryKey key="gradle.dependency.completion.contributor.local" defaultValue="true"
                 description="Gradle local repository dependency completion contributor enabled"/>
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.idea.reposearch">
    <contributor implementation="com.intellij.gradle.completion.GradleLocalDependencyCompletionContributor"/>
  </extensions>
</idea-plugin>
