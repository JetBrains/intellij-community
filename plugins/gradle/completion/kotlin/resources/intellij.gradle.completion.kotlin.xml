<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="org.jetbrains.kotlin"/>
    <module name="intellij.gradle"/>
    <module name="intellij.gradle.completion"/>
    <module name="intellij.gradle.java"/>
    <module name="intellij.java.frontback.psi.impl"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.repository.search.completion"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <completion.contributor language="kotlin"
                            id="KotlinGradleCleanupCompletionContributor"
                            order="first, before KotlinCompletionContributor, before liveTemplates"
                            implementationClass="com.intellij.gradle.completion.kotlin.KotlinGradleCleanupCompletionContributor"/>
    <completion.contributor language="kotlin"
                            id="KotlinGradleScriptCompletionContributor"
                            order="first, after KotlinGradleCleanupCompletionContributor"
                            implementationClass="com.intellij.gradle.completion.kotlin.KotlinGradleScriptCompletionContributor"/>
    <typedHandler implementation="com.intellij.gradle.completion.kotlin.KotlinGradleDependenciesAutoPopupHandler"
                  id="KotlinGradleDependenciesAutoPopupHandler"/>
    <typedHandler implementation="com.intellij.gradle.completion.kotlin.KotlinGradleTopLevelDependenciesAutoPopupHandler"
                  id="KotlinGradleTopLevelDependenciesAutoPopupHandler"/>
    <completion.confidence
      language="kotlin"
      implementationClass="com.intellij.gradle.completion.kotlin.EnableAutoPopupInKotlinGradleDependencyString"
      id="kotlinGradleDoNotSkipAutoPopupInDependencyStrings"
      order="before kotlinSkipAutopopupInStrings"/>
  </extensions>
</idea-plugin>
