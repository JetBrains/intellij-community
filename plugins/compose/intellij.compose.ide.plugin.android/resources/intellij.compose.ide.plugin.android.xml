<idea-plugin package="com.intellij.compose.ide.plugin.android">
  <dependencies>
    <plugin id="org.jetbrains.android"/>
    <module name="intellij.compose.ide.plugin.resources"/>
  </dependencies>

  <extensions defaultExtensionNs="com.intellij.compose.ide.plugin.resources">
    <drawablePreviewRenderer
      implementation="com.intellij.compose.ide.plugin.android.resources.AndroidDrawablePreviewRenderer"
      order="first"/>
  </extensions>

  <extensions defaultExtensionNs="com.android.tools.idea.npw.template">
    <wizardPluginPromotionTemplateProvider implementation="com.intellij.compose.ide.plugin.android.kmpPluginPromotion.KmpPluginPlaceholderProvider"/>
  </extensions>
</idea-plugin>