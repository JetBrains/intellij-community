<idea-plugin package="com.intellij.compose.ide.plugin.k2">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="com.intellij.modules.kotlin.k2"/>
    <module name="intellij.compose.ide.plugin.shared"/>
    <module name="intellij.gradle"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.completion.impl"/>
    <module name="intellij.kotlin.highlighting"/>
    <module name="intellij.kotlin.refactorings"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <codeinsight.quickfix.registrar implementation="com.intellij.compose.ide.plugin.k2.intentions.K2CreateComposableQuickFixesRegistrar"/>
    <callHighlighterExtension implementation="com.intellij.compose.ide.plugin.k2.highlighting.ComposableFunctionCallHighlighterExtension"/>
    <extractFunctionDescriptorModifier implementation="com.intellij.compose.ide.plugin.k2.K2ComposableAnnotationToExtractedFunctionAdder"
                                       order="last"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij.compose.ide.plugin.shared">
    <composeModuleConfiguration implementation="com.intellij.compose.ide.plugin.k2.inspections.K2GradleComposeModuleConfigurationExtension"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij">
    <completion.contributor language="kotlin"
                            implementationClass="com.intellij.compose.ide.plugin.k2.completion.K2ComposeModifierCompletionContributor"
                            order="first, before KotlinCompletionContributor"/>

    <codeInsight.lineMarkerProvider language="kotlin"
                                    implementationClass="com.intellij.compose.ide.plugin.k2.K2ComposeColorLineMarkerProviderDescriptor"/>
    <lang.foldingBuilder language="kotlin" implementationClass="com.intellij.compose.ide.plugin.k2.K2ComposeFoldingBuilder"/>

    <localInspection implementationClass="com.intellij.compose.ide.plugin.k2.inspections.K2ComposeMissingPluginInspection"
                     language="kotlin"
                     enabledByDefault="true"
                     bundle="messages.ComposeIdeBundle"
                     groupKey="compose.inspection.group.name"
                     key="compose.inspection.missing.plugin.name"
                     level="ERROR"
                     shortName="ComposableCallWithoutComposePlugin"/>

    <daemon.highlightInfoFilter implementation="com.intellij.compose.ide.plugin.k2.inspections.K2ComposeMissingDependencyHighlightFilter"/>
  </extensions>
</idea-plugin>