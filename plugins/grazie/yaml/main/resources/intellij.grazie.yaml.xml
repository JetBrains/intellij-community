<idea-plugin package="com.intellij.grazie.ide.language.yaml">
  <dependencies>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.yaml"/>
    <module name="intellij.yaml.backend"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="com.intellij.grazie">
    <textExtractor language="yaml" implementationClass="com.intellij.grazie.ide.language.yaml.YamlTextExtractor"/>
    <problemFilter language="yaml" implementationClass="com.intellij.grazie.ide.language.yaml.YamlProblemFilter"/>
  </extensions>
</idea-plugin>
