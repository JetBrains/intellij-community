<idea-plugin>
  <dependencies>
    <plugin id="org.intellij.intelliLang"/>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.java.langInjection"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.java.psi.impl"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.impl"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.indexing"/>
    <module name="intellij.platform.lang"/>
    <module name="intellij.platform.lang.impl"/>
    <module name="intellij.platform.langInjection"/>
    <module name="intellij.platform.projectModel"/>
    <module name="intellij.xml.psi"/>
    <!-- endregion -->
  </dependencies>
  <extensions defaultExtensionNs="org.intellij.intelliLang">
    <languageSupport implementation="com.intellij.groovy.langInjection.GroovyLanguageInjectionSupport"/>
    <injectionConfig config="resources/groovyInjections.xml"/>
  </extensions>
  <extensions defaultExtensionNs="org.intellij.groovy">
    <membersContributor implementation="com.intellij.groovy.langInjection.PatternEditorContextMembersProvider"/>
  </extensions>
  <extensions defaultExtensionNs="com.intellij">
    <multiHostInjector implementation="com.intellij.groovy.langInjection.GrConcatenation2InjectorAdapter" order="last"/>
    <multiHostInjector implementation="com.intellij.groovy.langInjection.GrConcatenationInjector"/>
    <concatenationAwareInjector implementation="com.intellij.groovy.langInjection.GrConcatenationAwareInjector"/>
  </extensions>
</idea-plugin>
