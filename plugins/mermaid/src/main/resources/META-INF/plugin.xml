<idea-plugin>
  <id>com.intellij.mermaid</id>
  <name>Mermaid</name>
  <vendor>JetBrains</vendor>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType name="Mermaid"
              implementationClass="com.intellij.mermaid.lang.MermaidFileType"
              fieldName="INSTANCE"
              language="Mermaid"
              extensions="mermaid"/>
    <lang.parserDefinition language="Mermaid"
                           implementationClass="com.intellij.mermaid.lang.MermaidParserDefinition"/>
    <lang.syntaxHighlighter language="Mermaid"
                            implementationClass="com.intellij.mermaid.lang.highlighting.MermaidHighlighter"/>
    <completion.contributor language="Mermaid"
                            implementationClass="com.intellij.mermaid.editor.MermaidCompletionContributor"/>
    <lang.commenter language="Mermaid"
                    implementationClass="com.intellij.mermaid.lang.MermaidCommenter"/>
    <lang.braceMatcher language="Mermaid"
                       implementationClass="com.intellij.mermaid.lang.highlighting.MermaidPairMatcher"/>
    <quoteHandler fileType="Mermaid"
                  className="com.intellij.mermaid.editor.MermaidQuoteHandler"/>

    <defaultLiveTemplates file="liveTemplates/MermaidHidden.xml" hidden="true"/>

    <lang.elementManipulator forClass="com.intellij.mermaid.lang.psi.MermaidNamedElement"
                             implementationClass="com.intellij.mermaid.lang.psi.MermaidIdentifierManipulator"/>
    <lang.findUsagesProvider language="Mermaid"
                             implementationClass="com.intellij.mermaid.lang.MermaidFindUsagesProvider"/>

    <lang.refactoringSupport language="Mermaid"
                             implementationClass="com.intellij.mermaid.lang.psi.MermaidRefactoringSupportProvider"/>

    <typedHandler implementation="com.intellij.mermaid.editor.MermaidTypedHandlerDelegate"/>

    <lang.formatter
      language="Mermaid"
      implementationClass="com.intellij.mermaid.lang.formatter.MermaidFormattingModelBuilder"/>
    <langCodeStyleSettingsProvider
      implementation="com.intellij.mermaid.lang.formatter.settings.MermaidCodeStyleSettingsProvider"/>
    <enterHandlerDelegate id="MermaidEnterHandler"
                          implementation="com.intellij.mermaid.editor.MermaidEnterHandler"/>

  </extensions>
</idea-plugin>
