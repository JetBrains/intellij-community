<idea-plugin allow-bundled-update="true">
  <id>com.intellij.searchEverywhereLucene</id>
  <name>SearchEverywhereLucene</name>
  <vendor>JetBrains</vendor>

  <!-- Declare split content modules that belong to this plugin -->
  <content namespace="jetbrains">
    <module name="intellij.searchEverywhereLucene.common" loading="embedded"/>
    <module name="intellij.searchEverywhereLucene.frontend"/>
    <module name="intellij.searchEverywhereLucene.backend"/>
  </content>
</idea-plugin>
