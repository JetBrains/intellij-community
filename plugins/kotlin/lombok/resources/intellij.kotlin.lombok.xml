<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java.impl"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.base.codeInsight"/>
    <module name="intellij.kotlin.base.projectStructure"/>
    <module name="intellij.kotlin.base.psi"/>
    <module name="intellij.kotlin.codeInsight.api"/>
    <module name="intellij.kotlin.codeInsight.shared"/>
    <module name="intellij.kotlin.projectConfiguration"/>
  </dependencies>
  <!-- endregion -->

  <resource-bundle>messages.LombokKotlinBundle</resource-bundle>

  <extensions defaultExtensionNs="com.intellij">
    <localInspection language="kotlin" implementationClass="org.jetbrains.kotlin.idea.lombok.inspections.LombokKotlinCompilerPluginInspection"
                     shortName="LombokKotlinCompilerPlugin"
                     key="lombok.kotlin.no.kotlin.lombok.compiler.plugin.inspection.problem.display.name"
                     groupBundle="messages.KotlinBundle" groupKey="group.names.kotlin" groupPath="Lombok"
                     level="WARNING" enabledByDefault="true"/>
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <projectPostConfigurator
            id="LombokCompilerPluginPostConfigurator"
            order="after SpringCompilerPluginPostConfigurator"
            implementation="org.jetbrains.kotlin.idea.lombok.configuration.LombokCompilerPluginProjectPostConfigurator"/>
  </extensions>
</idea-plugin>
