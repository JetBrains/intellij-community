<idea-plugin visibility="internal" package="org.jetbrains.kotlin.idea.core.script.k2.mainkts">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java.frontback.psi"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.repository.search.completion"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <psi.implicitReferenceProvider
        implementation="org.jetbrains.kotlin.idea.core.script.k2.mainkts.codeInsight.MainKtsReferenceProvider"/>

    <completion.contributor language="kotlin"
                            id="MainKtsDependsOnCompletionContributor"
                            implementationClass="org.jetbrains.kotlin.idea.core.script.k2.mainkts.codeInsight.MainKtsDependsOnCompletionContributor"/>

    <completion.confidence language="kotlin"
                           id="MainKtsDependsOnCompletionConfidence"
                           order="before kotlinSkipAutopopupInStrings"
                           implementationClass="org.jetbrains.kotlin.idea.core.script.k2.mainkts.codeInsight.MainKtsDependsOnCompletionConfidence"/>
  </extensions>
</idea-plugin>
