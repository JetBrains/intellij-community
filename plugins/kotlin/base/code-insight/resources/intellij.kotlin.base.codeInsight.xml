<idea-plugin visibility="public">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java"/>
    <module name="intellij.java.analysis"/>
    <module name="intellij.java.impl"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.java.syntax"/>
    <module name="intellij.java.backend"/>
    <module name="intellij.kotlin.base.codeInsight.minimal"/>
    <module name="intellij.kotlin.base.projectModel"/>
    <module name="intellij.kotlin.base.projectStructure"/>
    <module name="intellij.kotlin.base.resources"/>
    <module name="intellij.kotlin.formatter"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <codeInsight.linkHandler
            prefix="#kotlinClass/"
            handlerClass="org.jetbrains.kotlin.idea.highlighter.markers.KotlinClassTooltipLinkHandler"/>
    <qualifiedNameProvider implementation="org.jetbrains.kotlin.idea.KotlinQualifiedNameProvider"/>
    <runLineMarkerContributor
            language="kotlin"
            implementationClass="org.jetbrains.kotlin.idea.highlighter.KotlinTestRunLineMarkerContributor"/>
    <java.class.action.suppressor implementation="org.jetbrains.kotlin.idea.core.KotlinJavaClassActionSuppressor"/>
    <lang.inspectionSuppressor language="kotlin" implementationClass="org.jetbrains.kotlin.idea.inspections.suppress.KotlinInspectionSuppressor"/>
  </extensions>
</idea-plugin>
