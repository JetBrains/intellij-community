<idea-plugin visibility="internal" package="org.jetbrains.kotlin.idea.highlighting">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java.impl"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.base.resources"/>
    <module name="intellij.kotlin.codeInsight.shared"/>
    <module name="intellij.kotlin.highlighting.minimal"/>
    <module name="intellij.kotlin.searching"/>
  </dependencies>
  <!-- endregion -->

  <extensionPoints>
    <extensionPoint
            qualifiedName="org.jetbrains.kotlin.callHighlighterExtension"
            interface="org.jetbrains.kotlin.idea.highlighting.KotlinCallHighlighterExtension"
            dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <highlightRangeExtension implementation="org.jetbrains.kotlin.idea.highlighting.visitor.KotlinDiagnosticHighlightVisitor"/>
    <highlightVisitor implementation="org.jetbrains.kotlin.idea.highlighting.visitor.KotlinTypeSemanticHighlightingVisitor"/>
    <highlightVisitor implementation="org.jetbrains.kotlin.idea.highlighting.visitor.KotlinVariableReferenceSemanticHighlightingVisitor"/>
    <highlightVisitor implementation="org.jetbrains.kotlin.idea.highlighting.visitor.KotlinExpressionsSmartcastHighlightingVisitor"/>
    <highlightVisitor implementation="org.jetbrains.kotlin.idea.highlighting.visitor.KotlinDslSemanticHighlightingVisitor"/>
    <highlightVisitor implementation="org.jetbrains.kotlin.idea.highlighting.visitor.KotlinDiagnosticHighlightVisitor"/>
    <highlightVisitor implementation="org.jetbrains.kotlin.idea.highlighting.visitor.KotlinUnusedDeclarationHighlightingVisitor"/>
    <highlightVisitor implementation="org.jetbrains.kotlin.idea.highlighting.visitor.ParameterNamesHighlightingExtension"/>
    <highlightErrorFilter implementation="org.jetbrains.kotlin.idea.highlighting.visitor.KotlinHighlightInjectionErrorFilter"/>

    <highlightUsagesHandlerFactory implementation="org.jetbrains.kotlin.idea.highlighting.KotlinHighlightExitPointsHandlerFactory"/>

    <editorNotificationProvider implementation="org.jetbrains.kotlin.idea.highlighting.SupportAvailabilityNotificationProvider"/>

    <registryKey key="kotlin.highlighting.warmup"
                 description="Enables Kotlin highlighting warmup – triggers resolution in parallel to prefill caches"
                 defaultValue="true"/>
    <registryKey key="kotlin.highlighting.internal.show.diagnostic.names"
                 description="Shows diagnostic names in internal mode for debugging purposes."
                 defaultValue="true"/>

    <!--    <editorNotificationProvider implementation="org.jetbrains.kotlin.idea.highlighter.KMPSupportNotificationProvider"/>-->
    <!--    <defaultHighlightingSettingProvider implementation="org.jetbrains.kotlin.idea.highlighter.KMPHighlightingSettingsProvider"/>-->

    <defaultHighlightingSettingProvider implementation="org.jetbrains.kotlin.idea.highlighting.KotlinDefaultHighlightingSettingsProvider"/>

    <problemHighlightFilter implementation="org.jetbrains.kotlin.idea.highlighting.KotlinProblemHighlightFilter"/>
    <problemFileHighlightFilter implementation="org.jetbrains.kotlin.idea.highlighting.KotlinProblemFileHighlightFilter"/>


    <highlightVisitor implementation="org.jetbrains.kotlin.idea.highlighting.KotlinRainbowVisitor"/>
    <registryKey key="kotlin.highlight.stdlib.dsl.exit.points"
                 description="Enable highlighting of generator operators (yield, emit, add, etc.) in builder DSLs"
                 defaultValue="false"
                 restartRequired="false"/>
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <beforeResolveHighlightingVisitor implementation="org.jetbrains.kotlin.idea.highlighting.visitor.ParameterNamesHighlightingExtension"/>
    <beforeResolveHighlightingVisitor implementation="org.jetbrains.kotlin.idea.highlighting.beforeResolve.DeclarationHighlightingExtension"/>
    <beforeResolveHighlightingVisitor implementation="org.jetbrains.kotlin.idea.highlighting.beforeResolve.AnnotationsHighlightingExtension"/>
  </extensions>

</idea-plugin>
