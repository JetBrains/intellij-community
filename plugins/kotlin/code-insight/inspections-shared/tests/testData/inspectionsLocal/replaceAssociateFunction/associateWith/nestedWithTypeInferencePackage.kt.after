// PROBLEM: Replace 'associate' with 'associateWith'
// FIX: Replace with 'associateWith'
// WITH_STDLIB
package somepackage.subpackage

sealed class A {
    class B : A() {
        fun toC() = C()
    }
    class C : A()
}

fun transform(
    src: List<A.B>
): Map<A, A.C> {
    return src.associateWith { (it as A.B).toC() }
}