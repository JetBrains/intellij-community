<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.base.analysis"/>
    <module name="intellij.kotlin.base.psi"/>
    <module name="intellij.kotlin.codeInsight.liveTemplates"/>
    <module name="intellij.platform.structuralSearch"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <structuralsearch.profile implementation="org.jetbrains.kotlin.idea.k2.codeinsight.structuralsearch.KotlinStructuralSearchProfile"/>
    <structuralsearch.filterProvider implementation="org.jetbrains.kotlin.idea.k2.codeinsight.structuralsearch.filters.KotlinFilterProvider"/>
  </extensions>
</idea-plugin>