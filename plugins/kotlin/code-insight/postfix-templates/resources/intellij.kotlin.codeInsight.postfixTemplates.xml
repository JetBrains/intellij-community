<idea-plugin package="org.jetbrains.kotlin.idea.codeInsight.postfix">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.codeInsight.liveTemplates"/>
    <module name="intellij.kotlin.codeInsight.shared"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <codeInsight.template.postfixTemplateProvider
            language="kotlin"
            implementationClass="org.jetbrains.kotlin.idea.codeInsight.postfix.KotlinPostfixTemplateProvider"/>
  </extensions>
</idea-plugin>