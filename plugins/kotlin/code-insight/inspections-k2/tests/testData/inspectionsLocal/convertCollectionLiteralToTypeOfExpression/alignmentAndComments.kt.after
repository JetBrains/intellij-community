// COMPILER_ARGUMENTS: -Xcollection-literals
class MyCollection<T> {
    companion object { operator fun <T> of(vararg elements: T): MyCollection<T> = TODO() }
}

fun <T> testCollection(x: MyCollection<T>, y: MyCollection<T>) {
    println(x)
}

fun main() {
   testCollection(
       MyCollection.of(
           1,
           2, // comment
           3
       ),
        []
    )
}