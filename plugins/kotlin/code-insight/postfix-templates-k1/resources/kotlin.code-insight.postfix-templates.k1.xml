<idea-plugin package="org.jetbrains.kotlin.idea.codeInsight.postfix">
  <dependencies>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.java.psi"/>
    <module name="kotlin.code-insight.live-templates.k1"/>
    <module name="kotlin.code-insight.live-templates.shared"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <codeInsight.template.postfixTemplateProvider
            language="kotlin"
            implementationClass="org.jetbrains.kotlin.idea.codeInsight.postfix.KtPostfixTemplateProvider"/>
  </extensions>
</idea-plugin>