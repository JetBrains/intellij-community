<idea-plugin package="org.jetbrains.kotlin.idea.liveTemplates.k2">
  <dependencies>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.completion.impl"/>
    <module name="kotlin.code-insight.live-templates.shared"/>
    <!-- endregion -->
  </dependencies>
  <extensions defaultExtensionNs="com.intellij">
    <liveTemplateMacro implementation="org.jetbrains.kotlin.idea.liveTemplates.k2.macro.SymbolBasedAnonymousSuperMacro"/>
    <liveTemplateMacro implementation="org.jetbrains.kotlin.idea.liveTemplates.k2.macro.SymbolBasedSuggestVariableNameMacro"/>
    <liveTemplateMacro implementation="org.jetbrains.kotlin.idea.liveTemplates.k2.macro.SymbolBasedKotlinAnyVariableMacro"/>
    <liveTemplateMacro implementation="org.jetbrains.kotlin.idea.liveTemplates.k2.macro.SymbolBasedKotlinVariableMacro"/>
  </extensions>
</idea-plugin>