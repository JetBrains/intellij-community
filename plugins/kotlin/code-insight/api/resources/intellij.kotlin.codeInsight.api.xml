<idea-plugin visibility="public">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java.impl"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.base.projectStructure"/>
  </dependencies>
  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="org.jetbrains.kotlin.idea.codeinsight.api.applicators.fixes.KotlinQuickFixService"/>
    <applicationService serviceImplementation="org.jetbrains.kotlin.idea.codeinsight.api.applicators.fixes.KotlinQuickFixService"/>
  </extensions>
  <extensionPoints>
    <extensionPoint qualifiedName="org.jetbrains.kotlin.kaDanglingFileResolutionModeProvider"
                    interface="org.jetbrains.kotlin.idea.codeinsight.api.applicable.extensions.KaDanglingFileResolutionModeProvider"
                    dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.kotlin.autoImportCallableWeigher"
      interface="org.jetbrains.kotlin.idea.codeinsight.api.classic.quickfixes.KotlinAutoImportCallableWeigher"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="org.jetbrains.kotlin.equalsHashCodeGeneratorExtension"
      interface="org.jetbrains.kotlin.idea.codeinsight.api.applicable.extensions.KotlinEqualsHashCodeGeneratorExtension"
      dynamic="true"/>
    <extensionPoint qualifiedName="org.jetbrains.kotlin.codeinsight.quickfix.registrar"
                    interface="org.jetbrains.kotlin.idea.codeinsight.api.applicators.fixes.KotlinQuickFixRegistrar"
                    dynamic="true"/>
    <extensionPoint qualifiedName="org.jetbrains.kotlin.forwardDeclarationPolicyProvider"
                    interface="org.jetbrains.kotlin.idea.codeinsight.api.applicable.extensions.ForwardDeclarationPolicyProvider"
                    dynamic="true"/>
  </extensionPoints>
  <!-- endregion -->
</idea-plugin>
