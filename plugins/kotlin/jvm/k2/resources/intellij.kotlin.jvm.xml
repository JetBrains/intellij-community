<idea-plugin package="org.jetbrains.kotlin.idea.jvm.k2">
  <dependencies>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.java.frontback.psi"/>
    <module name="intellij.java.frontback.psi.impl"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.java.psi.impl"/>
    <module name="intellij.kotlin.base.scripting"/>
    <module name="intellij.kotlin.base.scripting.scratch.definition"/>
    <module name="intellij.kotlin.codeInsight"/>
    <module name="kotlin.jvm.shared"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <scratch.creationHelper language="kotlin"
                            implementationClass="org.jetbrains.kotlin.idea.jvm.k2.scratch.KotlinK2ScratchFileCreationHelper"/>

    <fileEditorProvider id="KtsScratchFileEditorProvider"
                        implementation="org.jetbrains.kotlin.idea.jvm.k2.scratch.K2ScratchFileEditorProvider"/>

    <projectService serviceInterface="org.jetbrains.kotlin.idea.jvm.shared.scratch.ScratchFileAutoRunner"
                    serviceImplementation="org.jetbrains.kotlin.idea.jvm.k2.scratch.ScratchFileAutoRunnerK2"/>
  </extensions>
  <resource-bundle>messages.KotlinBundle</resource-bundle>

  <actions>
    <action id="Kotlin.RunScratch" class="org.jetbrains.kotlin.idea.jvm.k2.scratch.RunScratchActionK2" icon="AllIcons.Actions.Execute">
      <keyboard-shortcut first-keystroke="control alt W" keymap="$default"/>
      <add-to-group group-id="RunContextPopupGroup" anchor="last"/>
    </action>
    <action id="Kotlin.ClearScratch" class="org.jetbrains.kotlin.idea.jvm.shared.scratch.actions.ClearScratchAction" icon="AllIcons.Actions.GC"/>
    <action id="Kotlin.StopScratch" class="org.jetbrains.kotlin.idea.jvm.shared.scratch.actions.StopScratchAction" icon="AllIcons.Actions.Suspend"/>
  </actions>

</idea-plugin>
