<idea-plugin>

  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <j2kConverterExtension implementation="org.jetbrains.kotlin.j2k.k2.K2J2KConverterExtension"/>
    <j2kPreprocessorExtension implementation="org.jetbrains.kotlin.j2k.k2.preProcessings.K2TypeArgumentsExpander"/>
  </extensions>

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java.frontback.psi"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.base.codeInsight"/>
    <module name="intellij.kotlin.base.projectStructure"/>
    <module name="intellij.kotlin.codeInsight.fixes"/>
  </dependencies>
  <!-- endregion -->

</idea-plugin>