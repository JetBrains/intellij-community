<idea-plugin package="org.jetbrains.kotlin.idea.j2k.old.post.processing">

  <extensions defaultExtensionNs="com.intellij">
    <applicationService
            serviceInterface="org.jetbrains.kotlin.j2k.OldJ2KPostProcessingRegistrar"
            serviceImplementation="org.jetbrains.kotlin.idea.j2k.old.post.processing.OldJ2KPostProcessingRegistrarImpl"/>
  </extensions>

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java.psi.impl"/>
    <module name="intellij.kotlin.codeInsight.shared"/>
    <module name="kotlin.code-insight.inspections.shared"/>
    <module name="kotlin.code-insight.intentions.shared"/>
  </dependencies>
  <!-- endregion -->

</idea-plugin>