<idea-plugin package="org.jetbrains.kotlin.idea.j2k.post.processing">

  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <j2kConverterExtension implementation="org.jetbrains.kotlin.idea.j2k.post.processing.NewJ2kConverterExtension"/>
  </extensions>

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.codeInsight.shared"/>
    <module name="kotlin.code-insight.inspections.shared"/>
    <module name="kotlin.code-insight.intentions.shared"/>
  </dependencies>
  <!-- endregion -->

</idea-plugin>