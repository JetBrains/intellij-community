<idea-plugin package="org.jetbrains.kotlin.idea.grazie">
  <dependencies>
    <plugin id="tanvd.grazi"/>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.grazie.core"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="com.intellij.grazie">
    <textExtractor language="kotlin" implementationClass="org.jetbrains.kotlin.idea.grazie.KotlinTextExtractor"/>
    <problemFilter language="kotlin" implementationClass="org.jetbrains.kotlin.idea.grazie.KotlinProblemFilter"/>
    <problemFilter language="kotlin" implementationClass="com.intellij.grazie.text.LiteralProblemFilter"/>
  </extensions>
</idea-plugin>