<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.gradle"/>
    <module name="intellij.java.impl"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.java.ui"/>
    <module name="intellij.kotlin.base.projectStructure"/>
    <module name="intellij.kotlin.base.resources"/>
    <module name="intellij.kotlin.projectConfiguration"/>
  </dependencies>
  <!-- endregion -->

  <extensionPoints>


    <extensionPoint
            qualifiedName="org.jetbrains.kotlin.idea.projectTemplatesProvider"
            interface="org.jetbrains.kotlin.tools.projectWizard.plugins.projectTemplates.ProjectTemplatesProvider" dynamic="true"/>

    <extensionPoint
            qualifiedName="org.jetbrains.kotlin.idea.androidSdkProvider"
            interface="org.jetbrains.kotlin.tools.projectWizard.plugins.AndroidSdkProvider" dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="org.jetbrains.kotlin.tools.projectWizard.compatibility.DependencyVersionStore"/>
    <applicationService serviceImplementation="org.jetbrains.kotlin.tools.projectWizard.compatibility.KotlinWizardVersionStore"/>
    <applicationService serviceImplementation="org.jetbrains.kotlin.tools.projectWizard.compatibility.KotlinGradleCompatibilityStore"/>
    <applicationService serviceImplementation="org.jetbrains.kotlin.tools.projectWizard.compatibility.KotlinLibrariesCompatibilityStore"/>
    <applicationService serviceImplementation="org.jetbrains.kotlin.tools.projectWizard.compatibility.GradleToPluginsCompatibilityStore"/>

    <applicationSettings service="org.jetbrains.kotlin.tools.projectWizard.compatibility.KotlinWizardVersionStore"/>
    <applicationSettings service="org.jetbrains.kotlin.tools.projectWizard.compatibility.DependencyVersionStore"/>
    <applicationSettings service="org.jetbrains.kotlin.tools.projectWizard.compatibility.KotlinLibrariesCompatibilityStore"/>
    <applicationSettings service="org.jetbrains.kotlin.tools.projectWizard.compatibility.KotlinGradleCompatibilityStore"/>
    <applicationSettings service="org.jetbrains.kotlin.tools.projectWizard.compatibility.GradleToPluginsCompatibilityStore"/>
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <libraryVersionProvider implementation="org.jetbrains.kotlin.tools.projectWizard.compatibility.DefaultKotlinLibraryVersionProvider"/>
  </extensions>
</idea-plugin>