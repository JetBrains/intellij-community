<idea-plugin visibility="public">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.java.debugger"/>
    <module name="intellij.java.debugger.impl"/>
    <module name="intellij.java.debugger.impl.shared"/>
    <module name="intellij.java.execution.impl"/>
    <module name="intellij.java.impl"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.base.analysis"/>
    <module name="intellij.kotlin.base.psi"/>
    <module name="intellij.kotlin.jvm.debugger.base.util"/>
    <module name="intellij.kotlin.jvm.debugger.core"/>
    <module name="intellij.libraries.maven.resolver.provider"/>
    <module name="intellij.platform.smRunner"/>
    <module name="kotlin.fir.frontend-independent"/>
  </dependencies>
  <!-- endregion -->
  <projectListeners>
    <listener class="org.jetbrains.kotlin.idea.debugger.coroutine.DisableCoroutineViewListener"
              topic="com.intellij.debugger.impl.DebuggerManagerListener"/>
  </projectListeners>
  <extensions defaultExtensionNs="com.intellij">
    <debugger.creationStackTraceProvider implementation="org.jetbrains.kotlin.idea.debugger.coroutine.CoroutineAsyncStackTraceProvider"/>
    <runConfigurationExtension implementation="org.jetbrains.kotlin.idea.debugger.coroutine.CoroutineDebugConfigurationExtension"/>
    <debugger.dumpItemsProvider implementation="org.jetbrains.kotlin.idea.debugger.coroutine.view.CoroutinesDumpAsyncProvider"/>
    <applicationService
            serviceInterface="org.jetbrains.kotlin.idea.debugger.core.StackFrameInterceptor"
            serviceImplementation="org.jetbrains.kotlin.idea.debugger.coroutine.CoroutineStackFrameInterceptor"/>
    <threadDumpItemFactory implementation="org.jetbrains.kotlin.idea.debugger.coroutine.view.CoroutineThreadDumpItemFactory"/>
  </extensions>
</idea-plugin>
