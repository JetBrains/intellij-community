// FILE: before.kt

fun some() {
    for (j in 0..5) {
        if (j == 1) <caret>continue
        for (i in 0..5) {
            break
        }
    }
}
// FILE: after.kt

fun some() {
    <caret>for (j in 0..5) {
        if (j == 1) continue
        for (i in 0..5) {
            break
        }
    }
}