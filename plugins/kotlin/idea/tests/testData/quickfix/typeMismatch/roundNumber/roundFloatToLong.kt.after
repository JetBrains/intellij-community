import kotlin.math.roundToLong

// "Round using roundToLong()" "true"
// PRIORITY: LOW
// WITH_STDLIB
// K2_ERROR: Argument type mismatch: actual type is 'Float', but 'Long' was expected.
fun test(f: Float) {
    bar(f.roundToLong())
}

fun bar(x: Long) {}
