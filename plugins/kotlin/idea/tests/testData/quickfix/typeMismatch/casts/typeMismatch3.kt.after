// "Cast expression 'a + a' to 'B'" "true"
// K2_ERROR: Return type mismatch: expected 'B', actual 'A'.
interface A {
    operator fun plus(x: Any): A
}
interface B : A

fun foo(a: A): B {
    return (a + a) as B
}
