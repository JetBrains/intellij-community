// "Wrap with '?.let { ... }' call" "true"
// WITH_STDLIB
// K2_ERROR: Reference has a nullable type '(String.() -> Unit)?'. Use explicit '?.invoke' to make a function-like call instead.

fun f(s: String, action: (String.() -> Unit)?) {
    action?.let { s.foo().bar().it() }
}

fun String.foo() = ""

fun String.bar() = ""
// FUS_QUICKFIX_NAME: org.jetbrains.kotlin.idea.quickfix.WrapWithSafeLetCallFix
