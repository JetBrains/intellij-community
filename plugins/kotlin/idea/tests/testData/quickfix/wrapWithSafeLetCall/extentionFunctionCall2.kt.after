// WITH_STDLIB
// K2_ERROR: UNSAFE_IMPLICIT_INVOKE_CALL

fun f(s: String, action: (String.() -> Unit)?) {
    action?.let { s.foo().bar().it() }
}

fun String.foo() = ""

fun String.bar() = ""
