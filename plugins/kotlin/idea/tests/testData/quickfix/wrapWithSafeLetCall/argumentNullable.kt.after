// "Wrap with '?.let { ... }' call" "true"
// WITH_STDLIB
// K2_ERROR: Argument type mismatch: actual type is 'String?', but 'String' was expected.

fun foo(x: String?) {
    x?.let { bar(it) }
}

fun bar(s: String) = s.hashCode()
