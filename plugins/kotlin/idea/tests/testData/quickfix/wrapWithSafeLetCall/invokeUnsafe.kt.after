// "Wrap with '?.let { ... }' call" "true"
// WITH_STDLIB
// K2_ERROR: Reference has a nullable type 'Int?'. Use explicit '?.invoke' to make a function-like call instead.

operator fun Int.invoke() = this

fun foo(arg: Int?) {
    arg?.let { it() }
}
