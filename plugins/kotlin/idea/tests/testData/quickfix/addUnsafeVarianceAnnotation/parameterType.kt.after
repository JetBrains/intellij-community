// "Add '@UnsafeVariance' annotation" "true"
// K2_ERROR: Type parameter 'E' is declared as 'out' but occurs in 'in' position in type 'E (of interface Foo<out E>)'.
interface Foo<out E> {
    fun bar(e: @UnsafeVariance E)
}
