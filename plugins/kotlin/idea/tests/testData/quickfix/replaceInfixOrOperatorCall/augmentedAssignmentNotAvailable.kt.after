// "Replace with safe (?.) call" "true"
// K2_ERROR: Operator call is prohibited on a nullable receiver of type 'A?'. Use '?.'-qualified call instead.
class A {
    operator fun plus(other: A) = this
}

fun foo(b: A) {
    var a: A? = A()
    a = a?.plus(b)
}
