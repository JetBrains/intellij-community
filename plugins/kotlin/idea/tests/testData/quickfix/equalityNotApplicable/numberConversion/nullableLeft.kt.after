// "Convert left-hand side to 'Long'" "true"
// K2_ERROR: Operator '==' cannot be applied to 'Short?' and 'Long?'.
fun test(s: Short?, l: Long?): Boolean {
    return s?.toLong() == l
}
// FUS_QUICKFIX_NAME: org.jetbrains.kotlin.idea.quickfix.NumberConversionFix
