// "Add else branch" "true"
// K2_ERROR: 'when' expression must be exhaustive. Add the 'G', 'B' branches or an 'else' branch.
enum class Color { R, G, B }
fun use(c: Color) {
    when (c) {
        Color.R -> red()
        else -> {<caret>}
    }
}

fun red() {}

