// "Use 'contextOf<Foo>()' as receiver" "true"
// COMPILER_ARGUMENTS: -Xcontext-parameters
// WITH_STDLIB
// API_VERSION: 2.2
// K2_ERROR: Call to 'fun bar(): Unit' defined in 'Foo' uses an implicit receiver shadowed by a context parameter. Make the receiver explicit using 'this' or 'contextOf<<anonymous>>()'.

interface Foo {
    fun bar() {
    }
}

fun Foo.test() {
    val o = object : Foo {}
    context(o) {
        contextOf<Foo>().bar<caret>()
    }
}

// FUS_K2_QUICKFIX_NAME: org.jetbrains.kotlin.idea.k2.codeinsight.fixes.AddContextParameterReceiverFix
