// "Convert to block body" "true"
// K2_ERROR: Returns are prohibited in functions with expression body. Use block body '{...}'.
fun foo(): Int {
    return when {
        true -> {
            if (true) return 1
            bar()
            2
        }

        else -> 3
    }
}

fun bar() {}
