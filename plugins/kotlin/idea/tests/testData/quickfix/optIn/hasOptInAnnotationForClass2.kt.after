// "Opt in for 'B' on containing class 'C'" "true"
// K2_ERROR: Base declaration of supertype 'I' needs opt-in. The declaration override must be annotated with '@B' or '@OptIn(B::class)'
@RequiresOptIn
annotation class A

@RequiresOptIn
annotation class B

interface I {
    @A
    fun foo(): Unit

    @B
    fun bar(): Unit
}

@OptIn(A::class, B::class)
class C : I {
    override fun foo() {}
    override fun bar() {}
}
