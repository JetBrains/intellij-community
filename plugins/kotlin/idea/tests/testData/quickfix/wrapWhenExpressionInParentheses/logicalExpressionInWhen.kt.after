// K2_ERROR: CONFUSING_BRANCH_CONDITION_ERROR
// K2_ERROR: NO_ELSE_IN_WHEN
interface A {
    operator fun contains(other: A): Boolean
}

fun test(x: A, b: Boolean) {
    when (b) {
        (x in x) -> {}
    }
}
