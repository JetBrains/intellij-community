fun main() {
    val list = listOf(1)
    val a = buildList {
        addAll(listOf(1, 2))
        list.mapTo(this) { it + 1}
        list.mapNotNullTo(this) { it + 1}
        list.mapIndexedTo(this) { i, e -> e - 2 }
        list.filterTo(this) { it % 2 == 1 }
        list.filterNotTo(this) { it % 2 == 1 }
        list.filterNotNullTo(this)
        list.filterIsInstanceTo<Int, _>(this)
        add(5)
    }
}