fun main() {
    val list = listOf(1)
    val a = buildList {
        addAll(listOf(1, 2))
        list.mapTo<Int, Int, _>(this) { it + 1 }
        list.mapNot<caret>NullTo<Int, Int, _>(this) { it + 1 }
        list.mapIndexedTo<Int, Int, _>(this) { i, e -> e - 2 }
        list.filterTo<Int, _>(this) { it % 2 == 1 }
        list.filterNotTo<Int, _>(this) { it % 2 == 1 }
        list.filterNotNullTo<_, Int>(this)
        list.filterIsInstanceTo<Int, _>(this)
        add(5)
    }
}