// COMPILER_ARGUMENTS: -Xcontext-parameters
// COMPILER_ARGUMENTS: -Xexplicit-context-arguments

class Logger

context(log: Logger)
fun process(data: String) {}

context(log: Logger)
fun doWork() {}

fun test() {
    val log = Logger()
    context(log) {
        process(data = "hello", log = log)
        doWork()
    }
}