<idea-plugin package="org.jetbrains.kotlin.idea.coverage">
  <dependencies>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <plugin id="Coverage"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.runConfigurations.jvm"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <javaCoverageEngineExtension implementation="org.jetbrains.kotlin.idea.coverage.KotlinCoverageExtension"/>
  </extensions>
</idea-plugin>
