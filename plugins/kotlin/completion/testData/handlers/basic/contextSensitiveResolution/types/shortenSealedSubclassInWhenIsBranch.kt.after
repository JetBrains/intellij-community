// FIR_COMPARISON
// FIR_IDENTICAL
package test

sealed class MyResult {
    class Ok(val v: String) : MyResult()
    class Err(val m: String) : MyResult()
}

fun handle(r: MyResult): String = when (r) {
    is Ok<caret> -> "ok"
    else -> "err"
}

// ELEMENT: Ok

// COMPILER_ARGUMENTS: -Xcontext-sensitive-resolution
