<idea-plugin package="com.intellij.mcpserver" allow-bundled-update="true">
  <name>MCP Server</name>
  <id>com.intellij.mcpServer</id>
  <category>AI-Powered</category>
  <description><![CDATA[
    MCP (Model Context Protocol) Server for IntelliJ IDEs
    This plugin integrates the MCP server into IntelliJ-based IDEs, enabling seamless communication between Large Language Models (LLMs)
    and your development environment. It provides tools for interacting with the IDE, including:
    <ul>
      <li>Reading the current file</li>
      <li>Executing terminal commands</li>
      <li>Setting breakpoints</li>
      <li>Searching project files</li>
      <li>And more</li>
    </ul>
  ]]></description>
  <vendor>JetBrains</vendor>

  <dependencies>
    <module name="intellij.libraries.kotlinx.io"/>
    <module name="intellij.libraries.ktor.client"/>
    <module name="intellij.libraries.ktor.io"/>
    <module name="intellij.libraries.ktor.network.tls"/>
    <module name="intellij.libraries.ktor.server.cio"/>
    <module name="intellij.libraries.ktor.client.cio"/>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.platform.compose"/>
    <!-- endregion -->
  </dependencies>
  <content namespace="jetbrains">
    <module name="intellij.mcpserver.vcs"/>
    <module name="intellij.mcpserver.terminal"/>
    <module name="intellij.mcpserver.terminal.frontend"/>
  </content>

  <extensionPoints>
    <extensionPoint name="mcpToolsProvider" interface="com.intellij.mcpserver.McpToolsProvider" dynamic="true" />
    <extensionPoint name="mcpToolFilterProvider" interface="com.intellij.mcpserver.McpToolFilterProvider" dynamic="true" />
    <extensionPoint name="mcpToolset" interface="com.intellij.mcpserver.McpToolset" dynamic="true" />
    <extensionPoint name="mcpProjectPathCustomizer" interface="com.intellij.mcpserver.McpProjectPathCustomizer" dynamic="true" />
    <extensionPoint name="mcpManagedSessionSupport" interface="com.intellij.mcpserver.McpManagedSessionSupport" dynamic="true" />
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.intellij.mcpserver.impl.util.network.McpServerConnectionAddressProvider"/>
    <applicationService serviceImplementation="com.intellij.mcpserver.impl.McpServerService"/>

    <serviceViewContributor implementation="com.intellij.mcpserver.services.McpServiceViewContributor"/>

    <statistics.counterUsagesCollector implementationClass="com.intellij.mcpserver.statistics.McpServerCounterUsagesCollector"/>
    <statistics.validation.customValidationRule implementation="com.intellij.mcpserver.statistics.McpServerCounterUsagesCollector$McpToolNameValidator"/>
    <statistics.applicationUsagesCollector implementation="com.intellij.mcpserver.statistics.McpServerApplicationUsagesCollector"/>

    <appStarter id="mcpServer" implementation="com.intellij.mcpserver.McpServerHeadlessStarter" internal="true"/>
    <backgroundPostStartupActivity implementation="com.intellij.mcpserver.impl.McpServerService$MyProjectListener" />
    <notificationGroup id="MCP Server" displayType="BALLOON" bundle="messages.McpServerBundle" key="notification.group.mcp.server"
      notificationIds="mcp.client.detected;mcp.client.autoconfigured;mcp.client.error.autoconfigured;mcp.client.wrong.port.detected"/>

    <mcpServer.mcpToolsProvider implementation="com.intellij.mcpserver.impl.ReflectionToolsProvider" />
    <mcpServer.mcpToolFilterProvider implementation="com.intellij.mcpserver.impl.DisallowListBasedMcpToolFilterProvider" />
    <mcpServer.mcpToolFilterProvider implementation="com.intellij.mcpserver.impl.SettingsBasedMcpToolFilterProvider" />
    <mcpServer.mcpToolFilterProvider implementation="com.intellij.mcpserver.impl.RegistryKeyMcpToolFilterProvider" />
    <mcpServer.mcpToolFilterProvider implementation="com.intellij.mcpserver.impl.IndividualRegistryKeyMcpToolFilterProvider" />

    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.ExecutionToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.AnalysisToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.FileToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.FormattingToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.UniversalToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.ReadToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.PatchToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.SearchToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.CodeInsightToolset" />
    <mcpServer.mcpToolset implementation="com.intellij.mcpserver.toolsets.general.RefactoringToolset" />

    <registryKey defaultValue="true"
                 description="Whether to return output schema and structured output from tools"
                 key="mcp.server.structured.tool.output"/>
    <registryKey defaultValue="false"
                 description="Support legacy MCP server name"
                 key="mcp.server.write.legacy.key"/>
    <registryKey defaultValue="true"
                 description="Enable OT tracer for MCP tool calls"
                 key="mcp.server.ot.trace"/>
    <registryKey defaultValue=""
                 description="Filter for MCP tools, like -*,+com.intellij.mcpserver.toolsets.general.*,-*.read_file"
                 key="mcp.server.tools.filter"/>
    <registryKey defaultValue="false"
                 description="Show advanced filter options UI in MCP tool filter settings"
                 key="mcp.server.show.advanced.filter.options.ui"/>

    <statusBarWidgetFactory id="McpServerStatusBarWidget"
                             implementation="com.intellij.mcpserver.widget.McpServerStatusBarWidgetFactory"
                             order="after PowerSaveMode"/>

    <applicationConfigurable
      instance="com.intellij.mcpserver.settings.McpServerSettingsConfigurable"
      id="com.intellij.mcpserver.settings"
      key="mcp.server.configurable.name"
      bundle="messages.McpServerBundle"
      dynamic="true"
      parentId="tools"/>

    <applicationConfigurable
      instance="com.intellij.mcpserver.settings.McpToolFilterConfigurable"
      id="com.intellij.mcpserver.settings.filter"
      key="configurable.mcp.tool.filter"
      bundle="messages.McpServerBundle"
      dynamic="true"
      parentId="com.intellij.mcpserver.settings"/>

    <applicationSettings service="com.intellij.mcpserver.settings.McpServerSettings"/>
    <applicationSettings service="com.intellij.mcpserver.settings.McpToolDisallowListSettings"/>
    <applicationSettings service="com.intellij.mcpserver.settings.McpToolFilterSettings"/>
  </extensions>

  <resource-bundle>messages.McpServerBundle</resource-bundle>

  <actions>
    <action id="com.intellij.mcpserver.actions.ShowMcpToolsAction" class="com.intellij.mcpserver.actions.ShowMcpToolsAction">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
