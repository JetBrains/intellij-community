{
  "name": "@jetbrains/intellij-webview",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./packages/api/src/index.ts",
      "default": "./packages/api/src/index.ts"
    },
    "./runtime": {
      "types": "./packages/runtime/src/index.ts",
      "default": "./packages/runtime/src/index.ts"
    },
    "./vite": {
      "types": "./packages/build/src/index.ts",
      "default": "./packages/build/src/index.ts"
    },
    "./tsconfig.view.json": "./tsconfig.view.json"
  },
  "scripts": {
    "build": "bun run build:bridge && bun run build:controls",
    "build:bridge": "bun run build.ts",
    "build:controls": "tsc -p packages/controls/tsconfig.json --noEmit",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  }
}
