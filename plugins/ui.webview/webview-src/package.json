{
  "name": "@jetbrains/intellij-webview",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./packages/api/src/index.ts",
      "default": "./packages/api/src/index.ts"
    },
    "./runtime": {
      "types": "./packages/runtime/src/index.ts",
      "default": "./packages/runtime/src/index.ts"
    },
    "./vite": {
      "types": "./packages/build/src/index.ts",
      "default": "./packages/build/src/index.ts"
    },
    "./tsconfig.view.json": "./tsconfig.view.json"
  },
  "scripts": {
    "build": "bun run build:bridge && bun run build:controls && bun run build:react-controls",
    "build:bridge": "bun run build.ts",
    "build:controls": "tsc -p packages/controls/tsconfig.json --noEmit",
    "build:react-controls": "tsc -p packages/react-controls/tsconfig.json --noEmit",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  }
}
