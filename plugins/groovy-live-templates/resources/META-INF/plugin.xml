<idea-plugin>
  <id>org.intellij.groovy.live.templates</id>
  <name>Groovy Live Templates</name>
  <description><![CDATA[
  Adds support for Groovy in IDE live templates.
  ]]></description>
  <vendor>JetBrains</vendor>

  <dependencies>
    <plugin id="org.intellij.groovy"/>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.libraries.groovy"/>
    <!-- endregion -->
  </dependencies>

  <content namespace="jetbrains">
  </content>

  <extensions defaultExtensionNs="com.intellij">
    <liveTemplateMacro implementation="com.intellij.groovy.live.templates.GroovyScriptMacro"/>
  </extensions>
</idea-plugin>
