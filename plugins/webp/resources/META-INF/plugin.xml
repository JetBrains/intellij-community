<idea-plugin allow-bundled-update="true">
  <id>intellij.webp</id>
  <vendor>JetBrains</vendor>
  <name>WebP</name>
  <description><![CDATA[
    <p>Allows viewing images in the <a href="https://developers.google.com/speed/webp">WebP</a> format in the IDE.</p>
    ]]></description>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="com.intellij.platform.images"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <fileType name="Image" extensions="webp"/>
    <imageReaderWriterSpi type="read" implementationClass="com.android.tools.adtui.webp.WebpImageReaderSpi"/>
    <imageReaderWriterSpi type="write" implementationClass="com.android.tools.adtui.webp.WebpImageWriterSpi"/>
  </extensions>
</idea-plugin>