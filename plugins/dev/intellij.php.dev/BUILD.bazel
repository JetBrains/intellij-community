load("@rules_jvm//:jvm.bzl", "resourcegroup")

resourcegroup(
  name = "php-dev_resources",
  srcs = glob(["resources/**/*"]),
  strip_prefix = "resources",
  visibility = ["//visibility:public"],  # used by @ultimate//:php-dev
)

filegroup(
  name = "php-dev_sources",
  srcs = glob(["src/**/*.kt", "src/**/*.java"], allow_empty = True),
  visibility = ["//visibility:public"],  # used by @ultimate//:php-dev
)
