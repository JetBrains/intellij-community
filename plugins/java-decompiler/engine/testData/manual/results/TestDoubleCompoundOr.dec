class TestDoubleCompoundOr {
   void mainTest() {
      int i = 0;// 3
      int i12 = 0;
      i -= 125;// 4
      i += i12 | i;// 5
      i += i12 | i;// 6
      System.out.println("i1:" + i);// 7
      int f1 = 1;// 8

      do {
         for(int var7 = 1; var7 < 6; ++var7) {// 10
            i += var7 | i;// 11
            System.out.println("i:" + i);// 12
         }

         ++f1;// 15
      } while(f1 < 299);

      System.out.println("result: " + i);// 17
   }// 18

   public static void main(String[] strArr) {
      TestDoubleCompoundOr _instance = new TestDoubleCompoundOr();// 20
      _instance.mainTest();// 21
   }// 22
}

