<idea-plugin>

  <dependencies>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.yaml"/>
    <module name="intellij.yaml.backend"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <yaml.tagRecogniser implementation="org.jetbrains.plugins.gitlab.yaml.GitlabYamlTagRecogniser"/>

    <statistics.applicationUsagesCollector
      implementation="org.jetbrains.plugins.gitlab.yaml.codeInsight.include.fus.GitLabCiIncludeApplicationMetricsCollector"/>
  </extensions>
</idea-plugin>