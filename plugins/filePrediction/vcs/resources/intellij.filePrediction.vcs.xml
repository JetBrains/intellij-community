<idea-plugin>
  <dependencies>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <plugin id="com.jetbrains.filePrediction"/>
    <module name="intellij.platform.vcs"/>
    <!-- endregion -->
  </dependencies>
  <extensions defaultExtensionNs="com.intellij">
    <filePrediction.candidateProvider implementation="com.intellij.filePrediction.vcs.FilePredictionVcsFilesProvider"/>
    <filePrediction.featureProvider implementation="com.intellij.filePrediction.vcs.FilePredictionVcsFeatures"/>
  </extensions>
</idea-plugin>
