<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.frontend"/>
    <module name="intellij.selucene.common"/>
  </dependencies>
  <!-- endregion -->

  <actions>
    <action id="com.intellij.selucene.HelloWorldAction" class="com.intellij.selucene.HelloWorldAction"
      text="Selucene: Hello World"
      description="Shows a hello world message from the Selucene plugin">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
