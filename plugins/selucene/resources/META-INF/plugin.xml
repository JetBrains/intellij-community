<idea-plugin allow-bundled-update="true">
  <id>com.intellij.selucene</id>
  <name>Selucene</name>
  <vendor>JetBrains</vendor>

  <!-- Declare split content modules that belong to this plugin -->
  <content namespace="jetbrains">
    <module name="intellij.selucene.common" loading="embedded"/>
    <module name="intellij.selucene.frontend"/>
    <module name="intellij.selucene.backend"/>
  </content>
</idea-plugin>
