<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.libraries.lucene.common"/>
    <module name="intellij.platform.backend"/>
    <module name="intellij.platform.rpc.backend"/>
    <module name="intellij.platform.searchEverywhere"/>
    <module name="intellij.selucene.common"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <searchEverywhere.itemsProviderFactory implementation="com.intellij.selucene.backend.providers.lucene.SeLuceneFilesProviderFactory"/>
  </extensions>

  <actions>
    <action id="Se.IndexFiles"
            class="com.intellij.selucene.backend.providers.lucene.debugActions.IndexFilesForLuceneAction"

            text="Index Files for Lucene"
            description="Index files for Lucene"
            icon="AllIcons.Actions.BuildLoadChanges"/>

    <action id="Se.DeleteLuceneIndex"
            class="com.intellij.selucene.backend.providers.lucene.debugActions.DeleteLuceneIndexAction"
            text="Delete SE Lucene Index"
            description="Deletes the SE Lucene index in the .idea folder"
            icon="AllIcons.Actions.ClearCash"/>
  </actions>

</idea-plugin>
