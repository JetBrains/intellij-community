<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.libraries.lucene.common"/>
    <module name="intellij.platform.backend"/>
    <module name="intellij.platform.rpc.backend"/>
    <module name="intellij.platform.searchEverywhere"/>
    <module name="intellij.selucene.common"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <searchEverywhere.itemsProviderFactory implementation="com.intellij.selucene.backend.providers.files.SeLuceneFilesProviderFactory"/>
    <vfs.asyncListener implementation="com.intellij.selucene.backend.providers.files.ChangeListener"/>
    <backgroundPostStartupActivity implementation="com.intellij.selucene.backend.providers.files.InitLuceneIndex"/>
  </extensions>

  <actions>
    <action id="Se.IndexFiles"
            class="com.intellij.selucene.backend.providers.files.debugActions.IndexFilesForLuceneAction"

            text="Index Files for Lucene"
            description="Index files for Lucene"
            icon="AllIcons.Actions.BuildLoadChanges"/>
  </actions>

</idea-plugin>
