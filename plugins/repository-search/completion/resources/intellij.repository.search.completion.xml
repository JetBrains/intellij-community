<idea-plugin visibility="internal">
  <extensionPoints>
    <extensionPoint qualifiedName="org.jetbrains.idea.reposearch.contributor"
                    interface="com.intellij.repository.search.completion.api.DependencyCompletionContributor" dynamic="true"/>
  </extensionPoints>
  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceInterface="com.intellij.repository.search.completion.api.DependencyCompletionService"
                        serviceImplementation="com.intellij.repository.search.completion.impl.DependencyCompletionServiceImpl"/>
    <statistics.collectorExtension
      implementation="com.intellij.repository.search.completion.statistics.DependencyCompletionUsageCollectorExtension"/>
    <lookup.usageDetails implementation="com.intellij.repository.search.completion.statistics.DependencyCompletionUsageDescriptor"/>

    <registryKey key="dependency.completion.local.results.delay.ms" defaultValue="3000"
                 description="Max wait time for server dependency completion results before local results are shown (ms)"/>
  </extensions>
</idea-plugin>
