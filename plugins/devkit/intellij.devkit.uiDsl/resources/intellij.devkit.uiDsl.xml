<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="org.jetbrains.kotlin"/>
    <module name="intellij.devkit.core"/>
    <module name="intellij.java.psi"/>
  </dependencies>
  <!-- endregion -->

  <resource-bundle>messages.DevkitUiDslBundle</resource-bundle>

  <extensions defaultExtensionNs="com.intellij">
    <registryKey key="devkit.uiDsl.usage.notification.enabled" defaultValue="false"
                 description="Add an editor notification for the first-time use of the Kotlin UI DSL"/>
  </extensions>

</idea-plugin>
