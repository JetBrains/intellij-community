// Predefined module kinds consumed by DevKit split-mode inspections.
// JSON5 comments, single-quoted strings, unquoted field names, and trailing commas are supported.
//
// Entry structure:
// {
//   kind: "moduleId",                                               // Required. Allowed values: "moduleId", "pluginId", "xmlDescriptorFile".
//   id: "intellij.platform.frontend",                               // Required for "moduleId" and "pluginId" entries. Must be omitted otherwise.
//   moduleName: "intellij.platform.resources",                      // Required for "xmlDescriptorFile" entries. Must be omitted otherwise.
//   descriptorRelativePath: "src/META-INF/PlatformLangPlugin.xml",  // Required for "xmlDescriptorFile" entries. Relative to the module content root.
//   moduleKind: "frontend",                                         // Required. Allowed values: "frontend", "backend", "shared", "monolith".
//   apiUsagePolicy: "backendWithNonUiApiPermit",                    // Optional. Allowed values: "backendWithNonUiApiPermit". Omit for default reporting.
// }
//
// "moduleId" entries are used when XML dependency analysis has only a module id/name, such as a <module name="..."/> value.
// "pluginId" entries are used for plugin ids declared inside descriptors.
// "xmlDescriptorFile" entries are used for a concrete XML descriptor inside a resolved module, useful when a single module contains many different XML descriptors historically
