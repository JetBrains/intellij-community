    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <postStartupActivity implementation="com.intellij.agent.workbench.sessions.cost.LiteLlmPriceCatalogStartupActivity"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij.agent.workbench">
    <sessionUsageCostCalculator implementation="com.intellij.agent.workbench.sessions.cost.LiteLlmAgentSessionUsageCostCalculator"/>
  </extensions>
</idea-plugin>
