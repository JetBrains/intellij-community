<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensionPoints>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.settingsContributor"
      interface="com.intellij.agent.workbench.settings.AgentWorkbenchSettingsContributor"
      dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationSettings service="com.intellij.agent.workbench.settings.AgentWorkbenchSettings"/>
    <applicationSettings service="com.intellij.agent.workbench.settings.AgentSessionProviderSettingsService"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij.agent.workbench">
    <sessionProviderFeatureSettings implementation="com.intellij.agent.workbench.settings.AgentWorkbenchProviderFeatureSettings"/>
  </extensions>
</idea-plugin>
