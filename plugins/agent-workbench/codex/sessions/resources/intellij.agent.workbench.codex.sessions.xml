<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.codex.common"/>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.core"/>
    <module name="intellij.agent.workbench.filewatch"/>
    <module name="intellij.agent.workbench.json"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions"/>
    <module name="intellij.agent.workbench.sessions.actions"/>
    <module name="intellij.agent.workbench.sessions.core"/>
    <module name="intellij.agent.workbench.sessions.cost"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="agentWorkbenchCodex"
      order="before agentWorkbenchClaude"
      implementation="com.intellij.agent.workbench.codex.sessions.CodexAgentSessionProviderDescriptor"/>
    <agent.workbench.mcpConfigProviderContributor
      implementation="com.intellij.agent.workbench.codex.sessions.CodexAwbMcpConfigProviderContributor"/>
    <agent.workbench.sessionLaunchContributor
      implementation="com.intellij.agent.workbench.codex.sessions.CodexMcpConfigLaunchContributor"/>
  </extensions>

</idea-plugin>
