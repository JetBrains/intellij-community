<idea-plugin>
  <resource-bundle>messages.AgentSessionsBundle</resource-bundle>

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.sessions"/>
    <module name="intellij.agent.workbench.sessions.actions"/>
    <module name="intellij.agent.workbench.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <statusBarWidgetFactory
      id="jbcentral.quota"
      implementation="com.intellij.agent.workbench.sessions.jbcentral.JbCentralQuotaStatusBarWidgetFactory"/>
    <applicationSettings service="com.intellij.agent.workbench.sessions.jbcentral.JbCentralQuotaHintStateService"/>
    <applicationSettings service="com.intellij.agent.workbench.sessions.jbcentral.JbCentralQuotaUsageHistoryService"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij.agent.workbench">
    <settingsContributor implementation="com.intellij.agent.workbench.sessions.jbcentral.JbCentralQuotaSettingsContributor"/>
  </extensions>

  <actions resource-bundle="messages.AgentSessionsBundle">
    <action
      id="AgentWorkbenchSessions.ToggleJbCentralQuotaWidget"
      class="com.intellij.agent.workbench.sessions.jbcentral.AgentSessionsToggleJbCentralQuotaWidgetAction">
      <add-to-group group-id="AgentWorkbenchSessions.ToolWindow.GearActions" anchor="after" relative-to-action="AgentWorkbenchSessions.ToggleSessionCost"/>
    </action>
  </actions>
</idea-plugin>
