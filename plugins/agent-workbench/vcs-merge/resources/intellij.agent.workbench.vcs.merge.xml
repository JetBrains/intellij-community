<idea-plugin>
  <resource-bundle>messages.AgentVcsMergeBundle</resource-bundle>

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.chat"/>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions"/>
    <module name="intellij.agent.workbench.sessions.core"/>
    <module name="intellij.platform.vcs"/>
    <module name="intellij.platform.vcs.impl"/>
    <module name="intellij.platform.vcs.impl.shared"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <openapi.vcs.merge.resolveActionProvider implementation="com.intellij.agent.workbench.vcs.merge.AgentMergeResolveActionProvider"/>
  </extensions>

  <actions>
    <action id="Merge.AgentResolveConflicts"
            class="com.intellij.agent.workbench.vcs.merge.AgentResolveConflictsAction"
            icon="AllIcons.Actions.InlayGear">
      <add-to-group group-id="Merge.Dialog.Iterative.ResolveActions"/>
    </action>
  </actions>
</idea-plugin>
