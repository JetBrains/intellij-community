<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.junie.common"/>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.json"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions"/>
    <module name="intellij.agent.workbench.sessions.actions"/>
    <module name="intellij.agent.workbench.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="agentWorkbenchJunie"
      order="after agentWorkbenchClaude"
      implementation="com.intellij.agent.workbench.junie.sessions.JunieAgentSessionProviderDescriptor"/>
    <agent.workbench.sessionLaunchContributor
      implementation="com.intellij.agent.workbench.junie.sessions.JunieAwbMcpLocationContributor"/>
  </extensions>
</idea-plugin>
