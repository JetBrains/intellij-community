<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="org.jetbrains.plugins.terminal"/>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.prompt.context"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions.core"/>
    <module name="intellij.terminal.frontend"/>
  </dependencies>
  <!-- endregion -->
  <resource-bundle>messages.AgentChatBundle</resource-bundle>

  <extensionPoints>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.chatTerminalTitleThreadRebindContributor"
      interface="com.intellij.agent.workbench.chat.AgentChatTerminalTitleThreadRebindContributor"
      dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceInterface="com.intellij.agent.workbench.sessions.core.providers.AgentOpenTopLevelThreadDispatchService"
                        serviceImplementation="com.intellij.agent.workbench.chat.AgentChatOpenTopLevelThreadDispatchService"/>
    <virtualFileSystem key="agent-chat" implementationClass="com.intellij.agent.workbench.chat.AgentChatVirtualFileSystem"/>
    <notificationGroup id="Agent Workbench Chat" displayType="BALLOON" bundle="messages.AgentChatBundle"
                       key="notification.group.agent.workbench.chat"/>
    <fileIconProvider implementation="com.intellij.agent.workbench.chat.AgentChatFileIconProvider"/>
    <fileEditorProvider id="agent.workbench-chat-editor" implementation="com.intellij.agent.workbench.chat.AgentChatFileEditorProvider"/>
    <editorTabTitleProvider implementation="com.intellij.agent.workbench.chat.AgentChatEditorTabTitleProvider"/>
    <editorTabColorProvider implementation="com.intellij.agent.workbench.chat.AgentChatEditorTabColorProvider"/>
    <applicationSettings service="com.intellij.agent.workbench.chat.AgentChatTabsStateService"/>
  </extensions>

  <applicationListeners>
    <listener class="com.intellij.agent.workbench.chat.AgentChatProjectColorChangeListener"
              topic="com.intellij.ide.ProjectColorChangeListener"/>
    <listener class="com.intellij.agent.workbench.chat.AgentChatSettingsChangeListener"
              topic="com.intellij.agent.workbench.sessions.core.settings.AgentWorkbenchSettingsListener"/>
    <listener class="com.intellij.agent.workbench.chat.AgentChatThreadPresentationStartupListener" activeInTestMode="true"
              activeInHeadlessMode="true"
              topic="com.intellij.ide.AppLifecycleListener"/>
  </applicationListeners>

  <extensions defaultExtensionNs="com.intellij.agent.workbench">
    <settingsContributor implementation="com.intellij.agent.workbench.chat.AgentChatSettingsContributor"/>
  </extensions>

  <actions resource-bundle="messages.AgentChatBundle">
    <action
      id="AgentWorkbenchSessions.EditorTab.PreviousProposedPlan"
      icon="AllIcons.Actions.PreviousOccurence"
      class="com.intellij.agent.workbench.chat.AgentChatPreviousProposedPlanAction"/>
    <action
      id="AgentWorkbenchSessions.EditorTab.NextProposedPlan"
      icon="AllIcons.Actions.NextOccurence"
      class="com.intellij.agent.workbench.chat.AgentChatNextProposedPlanAction"/>
  </actions>
</idea-plugin>
