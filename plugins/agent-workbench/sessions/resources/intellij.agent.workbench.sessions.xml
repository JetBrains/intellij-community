<idea-plugin>
  <resource-bundle>messages.AgentSessionsBundle</resource-bundle>

  <applicationListeners>
    <listener class="com.intellij.agent.workbench.sessions.frame.AgentChatThreadOutlineAvailabilitySettingsListener"
              topic="com.intellij.agent.workbench.settings.AgentWorkbenchSettingsListener"/>
  </applicationListeners>

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.chat"/>
    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
    <module name="intellij.agent.workbench.settings"/>
    <module name="intellij.agent.workbench.ui"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.promptLauncher implementation="com.intellij.agent.workbench.sessions.service.AgentSessionPromptLauncherBridge"/>
    <statistics.counterUsagesCollector
      implementationClass="com.intellij.agent.workbench.sessions.statistics.AgentWorkbenchFusCollector"/>
    <postStartupActivity implementation="com.intellij.agent.workbench.sessions.sleep.AgentSessionSleepPreventionStartupActivity"/>
    <notificationGroup id="Agent Workbench Sessions" displayType="BALLOON" bundle="messages.AgentSessionsBundle"
                       key="notification.group.agent.workbench.sessions"/>
    <applicationConfigurable
      instance="com.intellij.agent.workbench.sessions.settings.AgentWorkbenchSettingsConfigurable"
      id="com.intellij.agent.workbench.settings"
      key="settings.agent.workbench.name"
      bundle="messages.AgentSessionsBundle"
      dynamic="true"
      parentId="tools"/>
    <applicationConfigurable
      instance="com.intellij.agent.workbench.sessions.settings.AgentWorkbenchProvidersSettingsConfigurable"
      id="com.intellij.agent.workbench.settings.providers"
      key="settings.agent.workbench.providers.name"
      bundle="messages.AgentSessionsBundle"
      dynamic="true"
      parentId="com.intellij.agent.workbench.settings"/>
    <advancedSetting
      id="agent.workbench.chat.open.in.dedicated.frame"
      default="true"
      bundle="messages.AgentSessionsBundle"
      groupKey="advanced.settings.agent.workbench"
      visible="false"/>
    <advancedSetting
      id="agent.workbench.prevent.system.sleep.while.working"
      default="true"
      bundle="messages.AgentSessionsBundle"
      groupKey="advanced.settings.agent.workbench"/>
    <advancedSetting
      id="agent.workbench.sessions.thread.cost.enabled"
      default="false"
      bundle="messages.AgentSessionsBundle"
      groupKey="advanced.settings.agent.workbench"
      visible="false"/>
    <projectFrameCapabilitiesProvider implementation="com.intellij.agent.workbench.sessions.frame.AgentWorkbenchProjectFrameCapabilitiesProvider"/>
    <toolWindow
      id="agent.workbench.chat.thread.outline"
      anchor="left"
      icon="com.intellij.agent.workbench.sessions.icons.AgentWorkbenchSessionsIcons.ThreadOutline"
      secondary="true"
      canCloseContents="false"
      factoryClass="com.intellij.agent.workbench.sessions.frame.AgentChatThreadOutlineToolWindowFactory"/>
    <projectFrameToolWindowLayout id="agent.workbench.dedicated" frameType="AGENT_DEDICATED" applyMode="forceOnce" migrationVersion="5">
      <toolWindow id="Project" register="false"/>
      <toolWindow id="Structure" register="false"/>
      <toolWindow id="agent.workbench.sessions" anchor="left" visible="true" showStripeButton="true" weight="0.25"/>
      <toolWindow id="agent.workbench.chat.thread.outline" anchor="left" visible="true" showStripeButton="true" weight="0.25"/>
      <toolWindow id="Terminal" anchor="bottom" visible="false" showStripeButton="true"/>
    </projectFrameToolWindowLayout>
    <projectFrameActionExclusion frameType="AGENT_DEDICATED" place="MainToolbar" id="MainToolbarVCSGroup"/>
    <projectFrameActionExclusion frameType="AGENT_DEDICATED" place="MainToolbar" id="ExecutionTargetsToolbarGroup"/>
    <projectFrameActionExclusion frameType="AGENT_DEDICATED" place="MainToolbar" id="NewUiRunWidget"/>
    <projectFrameActionExclusion frameType="AGENT_DEDICATED" place="MainToolbar" id="AIAssistantHubPopupAction"/>
    <projectFrameActionExclusion frameType="AGENT_DEDICATED" place="MainToolbar" id="BuildSolutionBar"/>
    <projectFrameActionExclusion frameType="AGENT_DEDICATED" place="MainToolbar" id="ActiveDeviceGroup"/>
    <applicationSettings service="com.intellij.agent.workbench.sessions.state.AgentSessionTreeUiStateService"/>
    <applicationSettings service="com.intellij.agent.workbench.sessions.state.AgentSessionLaunchProfileStateService"/>
    <applicationSettings service="com.intellij.agent.workbench.sessions.state.AgentSessionUiPreferencesStateService"/>
    <applicationSettings service="com.intellij.agent.workbench.sessions.state.AgentSessionWarmStateService"/>
    <applicationSettings service="com.intellij.agent.workbench.sessions.AgentSessionCostHintStateService"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij.agent.workbench">
    <settingsContributor implementation="com.intellij.agent.workbench.sessions.settings.AgentSessionCostSettingsContributor"/>
  </extensions>
</idea-plugin>
