<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="org.jetbrains.plugins.terminal"/>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.filewatch"/>
    <module name="intellij.agent.workbench.json"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions"/>
    <module name="intellij.agent.workbench.sessions.core"/>
    <module name="intellij.terminal.backend"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="agentWorkbenchPi"
      order="after agentWorkbenchJunie"
      implementation="com.intellij.agent.workbench.pi.sessions.PiAgentSessionProviderDescriptor"/>
  </extensions>

  <applicationListeners>
    <listener class="com.intellij.agent.workbench.pi.sessions.PiThemeChangeListener"
              topic="com.intellij.openapi.editor.colors.EditorColorsListener"/>
    <listener class="com.intellij.agent.workbench.pi.sessions.PiThemeChangeListener"
              topic="com.intellij.ide.ui.LafManagerListener"/>
  </applicationListeners>
</idea-plugin>
