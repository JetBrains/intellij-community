<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.backend"/>
  </dependencies>
  <!-- endregion -->

  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.agent.workbench.discoveryInfoContributor"
                    interface="com.intellij.agent.workbench.discoverability.DiscoveryInfoContributor"
                    dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.discoveryInfoContributor implementation="com.intellij.agent.workbench.discoverability.OpenedProjectRootsContributor"/>
    <postStartupActivity implementation="com.intellij.agent.workbench.discoverability.OpenedProjectRootsContributor"/>
  </extensions>

  <applicationListeners>
    <listener class="com.intellij.agent.workbench.discoverability.ProjectRootsProjectCloseListener"
              topic="com.intellij.openapi.project.ProjectCloseListener"/>
  </applicationListeners>
</idea-plugin>
