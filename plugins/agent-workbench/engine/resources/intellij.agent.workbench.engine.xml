<idea-plugin>
  <resource-bundle>messages.EngineBundle</resource-bundle>

  <dependencies>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
    <module name="intellij.agent.workbench.chat"/>
  </dependencies>

  <extensionPoints>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.engine.promptSender"
      interface="com.intellij.agent.workbench.engine.platform.EnginePromptSender"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.engine.launchAgentProvider"
      interface="com.intellij.agent.workbench.engine.platform.EngineLaunchAgentProvider"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.engine.runtimeConnector"
      interface="com.intellij.agent.workbench.engine.platform.EngineRuntimeConnector"
      dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="agentWorkbenchEngine"
      implementation="com.intellij.agent.workbench.engine.ui.EngineSessionProviderDescriptor"/>
    <agent.workbench.chatCustomContent
      implementation="com.intellij.agent.workbench.engine.ui.EngineChatCustomContentProvider"/>
  </extensions>

  <actions>
    <action
      id="Acp.RunMockThread"
      class="com.intellij.agent.workbench.engine.ui.RunMockThreadAction"/>
  </actions>
</idea-plugin>