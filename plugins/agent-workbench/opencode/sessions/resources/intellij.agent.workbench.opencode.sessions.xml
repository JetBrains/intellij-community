<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="org.jetbrains.plugins.terminal"/>
    <module name="intellij.agent.workbench.cli"/>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.json"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions.core"/>
    <module name="intellij.terminal.backend"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="agentWorkbenchOpenCode"
      order="after agentWorkbenchPi, before agentWorkbenchTerminal"
      implementation="com.intellij.agent.workbench.opencode.sessions.OpenCodeAgentSessionProviderDescriptor"/>
    <agent.workbench.sessionLaunchContributor implementation="com.intellij.agent.workbench.opencode.sessions.OpenCodeMcpUrlLaunchContributor"/>
  </extensions>
</idea-plugin>
