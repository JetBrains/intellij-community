<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.core"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="agentWorkbenchTerminal"
      order="after agentWorkbenchPi"
      implementation="com.intellij.agent.workbench.terminal.sessions.TerminalAgentSessionProviderDescriptor"/>
    <agent.workbench.sessionLaunchContributor implementation="com.intellij.agent.workbench.terminal.sessions.TerminalSessionLaunchContributor"/>
    <applicationSettings service="com.intellij.agent.workbench.terminal.sessions.TerminalSessionStateService"/>
  </extensions>
</idea-plugin>
