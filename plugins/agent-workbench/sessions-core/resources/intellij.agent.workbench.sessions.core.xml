<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.common"/>
  </dependencies>
  <!-- endregion -->

  <extensionPoints>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.sessionProvider"
      interface="com.intellij.agent.workbench.sessions.core.providers.AgentSessionProviderDescriptor"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptLauncher"
      interface="com.intellij.agent.workbench.sessions.core.prompt.AgentPromptLauncherBridge"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptContextContributor"
      interface="com.intellij.agent.workbench.sessions.core.prompt.AgentPromptContextContributorBridge"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptContextRenderer"
      interface="com.intellij.agent.workbench.sessions.core.prompt.AgentPromptContextRendererBridge"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptPaletteExtension"
      interface="com.intellij.agent.workbench.sessions.core.prompt.AgentPromptPaletteExtension"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptManualContextSource"
      interface="com.intellij.agent.workbench.sessions.core.prompt.AgentPromptManualContextSourceBridge"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptSuggestionAiBackend"
      interface="com.intellij.agent.workbench.sessions.core.prompt.AgentPromptSuggestionAiBackend"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.sessionLaunchSpecAugmenter"
      interface="com.intellij.agent.workbench.sessions.core.launch.AgentSessionLaunchSpecAugmenter"
      dynamic="true"/>
  </extensionPoints>
</idea-plugin>