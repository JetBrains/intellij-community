<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.prompt.core"/>
  </dependencies>
  <!-- endregion -->

  <extensionPoints>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.sessionProvider"
      interface="com.intellij.agent.workbench.sessions.core.providers.AgentSessionProviderDescriptor"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.sessionLaunchSpecAugmenter"
      interface="com.intellij.agent.workbench.sessions.core.launch.AgentSessionLaunchSpecAugmenter"
      dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <statistics.counterUsagesCollector implementationClass="com.intellij.agent.workbench.sessions.core.statistics.AgentWorkbenchFusCollector"/>
  </extensions>
</idea-plugin>
