<idea-plugin>
  <resource-bundle>messages.ClaudeSessionsBundle</resource-bundle>

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.settings"/>
    <module name="intellij.agent.workbench.ui"/>
    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.platform.ai.agent.json"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <statusBarWidgetFactory
      id="claude.quota"
      implementation="com.intellij.platform.ai.agent.claude.sessions.ClaudeQuotaStatusBarWidgetFactory"/>
    <applicationSettings service="com.intellij.platform.ai.agent.claude.sessions.ClaudeQuotaHintStateService"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij.agent.workbench">
    <settingsContributor implementation="com.intellij.platform.ai.agent.claude.sessions.ClaudeQuotaSettingsContributor"/>
    <sessionProviderUiContributor providerId="claude"
                                  implementation="com.intellij.platform.ai.agent.claude.sessions.ClaudeQuotaSessionProviderUiContributor"/>
  </extensions>
</idea-plugin>
