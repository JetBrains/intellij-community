<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.common"/>
  </dependencies>
  <!-- endregion -->

  <resource-bundle>messages.AgentPromptSuggestionsBundle</resource-bundle>

  <extensionPoints>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptLauncher"
      interface="com.intellij.agent.workbench.prompt.core.AgentPromptLauncherBridge"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptContextContributor"
      interface="com.intellij.agent.workbench.prompt.core.AgentPromptContextContributorBridge"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptContextRenderer"
      interface="com.intellij.agent.workbench.prompt.core.AgentPromptContextRendererBridge"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptPaletteExtension"
      interface="com.intellij.agent.workbench.prompt.core.AgentPromptPaletteExtension"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptManualContextSource"
      interface="com.intellij.agent.workbench.prompt.core.AgentPromptManualContextSourceBridge"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.promptSuggestionAiBackend"
      interface="com.intellij.agent.workbench.prompt.core.AgentPromptSuggestionAiBackend"
      dynamic="true"/>
    <extensionPoint
      qualifiedName="com.intellij.agent.workbench.containerLauncher"
      interface="com.intellij.agent.workbench.prompt.core.AgentPromptContainerLauncher"
      dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.promptContextRenderer implementation="com.intellij.agent.workbench.prompt.core.AgentPromptFileContextRendererBridge"/>
    <agent.workbench.promptContextRenderer implementation="com.intellij.agent.workbench.prompt.core.AgentPromptPathsContextRendererBridge"/>
    <agent.workbench.promptContextRenderer implementation="com.intellij.agent.workbench.prompt.core.AgentPromptSnippetContextRendererBridge"/>
    <agent.workbench.promptContextRenderer implementation="com.intellij.agent.workbench.prompt.core.AgentPromptSymbolContextRendererBridge"/>
  </extensions>
</idea-plugin>
