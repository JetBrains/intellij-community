<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.prompt.ui"/>
    <module name="intellij.platform.testRunner"/>
  </dependencies>
  <!-- endregion -->

  <resource-bundle>messages.AgentPromptTestRunnerBundle</resource-bundle>

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.promptContextContributor id="agentWorkbenchPromptTestRunnerContext" implementation="com.intellij.agent.workbench.prompt.testrunner.context.AgentPromptTestSelectionContextContributor" order="before agentWorkbenchPromptEditorContext"/>
    <agent.workbench.promptContextRenderer implementation="com.intellij.agent.workbench.prompt.testrunner.render.AgentPromptTestFailuresContextRendererBridge"/>
  </extensions>

  <actions>
    <reference ref="AgentWorkbenchPrompt.AddToAgentContext">
      <add-to-group group-id="TestTreePopupMenu" anchor="last"/>
    </reference>
  </actions>
</idea-plugin>
