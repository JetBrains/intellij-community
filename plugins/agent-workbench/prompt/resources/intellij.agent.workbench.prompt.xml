<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <resource-bundle>messages.AgentPromptBundle</resource-bundle>

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.promptContextContributor implementation="com.intellij.agent.workbench.prompt.context.AgentPromptEditorContextContributor"/>
    <agent.workbench.promptContextContributor implementation="com.intellij.agent.workbench.prompt.context.AgentPromptProjectViewSelectionContextContributor"/>
    <agent.workbench.promptContextContributor implementation="com.intellij.agent.workbench.prompt.context.AgentPromptSelectedEditorFallbackContextContributor"/>
  </extensions>

  <actions resource-bundle="messages.AgentPromptBundle">
    <action
      id="AgentWorkbenchPrompt.OpenGlobalPalette"
      class="com.intellij.agent.workbench.prompt.actions.AgentWorkbenchGlobalPromptAction">
      <keyboard-shortcut first-keystroke="control BACK_SLASH" keymap="$default"/>
      <keyboard-shortcut first-keystroke="meta BACK_SLASH" keymap="Mac OS X 10.5+"/>
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
