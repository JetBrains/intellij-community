<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.agent.workbench.prompt.context"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
    <module name="intellij.agent.workbench.settings"/>
    <module name="intellij.agent.workbench.ui"/>
    <module name="intellij.markdown"/>
  </dependencies>
  <!-- endregion -->

  <resource-bundle>messages.AgentPromptBundle</resource-bundle>

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.promptManualContextSource implementation="com.intellij.agent.workbench.prompt.ui.context.AgentPromptProjectPathsManualContextSource"/>
    <agent.workbench.promptManualContextSource implementation="com.intellij.agent.workbench.prompt.ui.context.uiPicker.AgentPromptUIContextManualContextSource"/>
    <agent.workbench.promptManualContextSource implementation="com.intellij.agent.workbench.prompt.ui.context.screenCapture.AgentPromptScreenCaptureManualContextSource"/>
    <customPasteProvider implementation="com.intellij.agent.workbench.prompt.ui.context.AgentPromptImagePasteProvider"/>
    <actionPromoter implementation="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchPromptShortcutActionPromoter" order="last"/>
    <editorFloatingToolbarProvider
      implementation="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchScratchPromptFloatingToolbarProvider"
      id="AgentWorkbenchScratchPromptFloatingToolbarProvider"/>
    <editorEmptyTextProvider
      implementation="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchGlobalPromptEmptyTextProvider"
      order="first"/>
    <editorEmptyStateComponentProvider implementation="com.intellij.agent.workbench.prompt.ui.emptyState.AgentWorkbenchInlinePromptEmptyStateProvider"/>
    <projectSettings service="com.intellij.agent.workbench.prompt.ui.AgentPromptUiSessionStateService"/>
    <intentionAction>
      <className>com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchAddToAgentContextIntention</className>
      <bundleName>messages.AgentPromptBundle</bundleName>
      <categoryKey>intention.category.agent.workbench</categoryKey>
      <skipBeforeAfter>true</skipBeforeAfter>
    </intentionAction>
  </extensions>

  <actions resource-bundle="messages.AgentPromptBundle">
    <action
      id="AgentWorkbenchPrompt.AddToAgentContext"
      class="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchAddToAgentContextAction">
      <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="Copy.Paste.Special"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="after" relative-to-action="ProjectViewEditSource"/>
      <add-to-group group-id="EditorTabPopupMenu" anchor="after" relative-to-action="CopyPaths"/>
      <add-to-group group-id="ConsoleEditorPopupMenu" anchor="after" relative-to-action="$SearchWeb"/>
    </action>

    <action
      id="AgentWorkbenchPrompt.OpenScratchAsPrompt"
      class="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchOpenScratchAsPromptAction"
      icon="AllIcons.Actions.InlayGear">
      <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="AgentWorkbenchPrompt.AddToAgentContext"/>
    </action>

    <group id="AgentWorkbenchPrompt.ScratchPromptEditorContextBarGroup">
      <reference ref="AgentWorkbenchPrompt.OpenScratchAsPrompt"/>
    </group>

    <action
      id="AgentWorkbenchPrompt.ManageLaunchProfiles"
      class="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchManageLaunchProfilesAction"/>

    <action
      id="AgentWorkbenchPrompt.OpenGlobalPalette"
      class="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchGlobalPromptAction">
      <keyboard-shortcut first-keystroke="control BACK_SLASH" keymap="$default"/>
      <keyboard-gesture-shortcut keystroke="ctrl control" modifier="dblClick" keymap="$default"/>
      <keyboard-shortcut first-keystroke="meta BACK_SLASH" keymap="Mac OS X 10.5+"/>
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>

    <action
      id="AgentWorkbenchPrompt.OpenGlobalPaletteAutoSelect"
      class="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchGlobalPromptAutoSelectAction">
      <keyboard-shortcut first-keystroke="alt control BACK_SLASH" keymap="$default"/>
      <keyboard-gesture-shortcut keystroke="alt ctrl control" modifier="dblClick" keymap="$default"/>
      <keyboard-shortcut first-keystroke="alt meta BACK_SLASH" keymap="Mac OS X 10.5+"/>
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
