<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions.core"/>
    <module name="intellij.markdown"/>
  </dependencies>
  <!-- endregion -->

  <resource-bundle>messages.AgentPromptBundle</resource-bundle>

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.promptManualContextSource implementation="com.intellij.agent.workbench.prompt.ui.context.AgentPromptProjectPathsManualContextSource"/>
    <agent.workbench.promptManualContextSource implementation="com.intellij.agent.workbench.prompt.ui.context.uiPicker.AgentPromptUIContextManualContextSource"/>
    <agent.workbench.promptManualContextSource implementation="com.intellij.agent.workbench.prompt.ui.context.screenCapture.AgentPromptScreenCaptureManualContextSource"/>
    <customPasteProvider implementation="com.intellij.agent.workbench.prompt.ui.context.AgentPromptImagePasteProvider"/>
    <agent.workbench.promptContextContributor id="agentWorkbenchPromptEditorContext" implementation="com.intellij.agent.workbench.prompt.ui.context.AgentPromptEditorContextContributor"/>
    <agent.workbench.promptContextContributor id="agentWorkbenchPromptProjectViewContext" implementation="com.intellij.agent.workbench.prompt.ui.context.AgentPromptProjectViewSelectionContextContributor" order="after agentWorkbenchPromptVcsContext, before agentWorkbenchPromptTreeSelectionContext"/>
    <agent.workbench.promptContextContributor id="agentWorkbenchPromptSelectedEditorFallbackContext" implementation="com.intellij.agent.workbench.prompt.ui.context.AgentPromptSelectedEditorFallbackContextContributor"/>
    <agent.workbench.promptContextContributor id="agentWorkbenchPromptTreeSelectionContext" implementation="com.intellij.agent.workbench.prompt.ui.context.AgentPromptTreeSelectionContextContributor" order="after agentWorkbenchPromptProjectViewContext"/>
    <agent.workbench.promptContextContributor id="agentWorkbenchPromptListSelectionContext" implementation="com.intellij.agent.workbench.prompt.ui.context.AgentPromptListSelectionContextContributor" order="after agentWorkbenchPromptTreeSelectionContext"/>
    <actionPromoter implementation="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchPromptShortcutActionPromoter" order="last"/>
  </extensions>

  <actions resource-bundle="messages.AgentPromptBundle">
    <action
      id="AgentWorkbenchPrompt.OpenGlobalPalette"
      class="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchGlobalPromptAction">
      <keyboard-shortcut first-keystroke="control BACK_SLASH" keymap="$default"/>
      <keyboard-shortcut first-keystroke="meta BACK_SLASH" keymap="Mac OS X 10.5+"/>
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>

    <action
      id="AgentWorkbenchPrompt.OpenGlobalPaletteAutoSelect"
      class="com.intellij.agent.workbench.prompt.ui.actions.AgentWorkbenchGlobalPromptAutoSelectAction">
      <keyboard-shortcut first-keystroke="alt control BACK_SLASH" keymap="$default"/>
      <keyboard-shortcut first-keystroke="alt meta BACK_SLASH" keymap="Mac OS X 10.5+"/>
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
