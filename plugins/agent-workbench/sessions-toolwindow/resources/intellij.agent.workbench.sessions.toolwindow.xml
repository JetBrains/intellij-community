<idea-plugin>
  <resource-bundle>messages.AgentSessionsBundle</resource-bundle>

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.thread.view"/>
    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions"/>
    <module name="intellij.agent.workbench.sessions.task.folders"/>
    <module name="intellij.agent.workbench.sessions.actions"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
    <module name="intellij.agent.workbench.sessions.jbcentral"/>
    <module name="intellij.agent.workbench.settings"/>
    <module name="intellij.agent.workbench.ui"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <toolWindow
      id="agent.workbench.sessions"
      anchor="left"
      secondary="true"
      icon="com.intellij.agent.workbench.sessions.toolwindow.icons.AgentWorkbenchSessionsToolwindowIcons.Alien"
      canCloseContents="false"
      factoryClass="com.intellij.agent.workbench.sessions.toolwindow.ui.AgentSessionsToolWindowFactory"/>
    <postStartupActivity implementation="com.intellij.agent.workbench.sessions.toolwindow.ui.AgentSessionsActivityStartupActivity"/>
    <defaultToolWindowLayout implementation="com.intellij.agent.workbench.sessions.toolwindow.ui.AgentSessionsToolWindowDefaultLayoutExtension" order="last"/>
  </extensions>

  <actions resource-bundle="messages.AgentSessionsBundle">
    <!-- Toolbar (title actions) slot other runtimes (e.g. ACP) contribute buttons into. -->
    <group id="AgentWorkbenchSessions.ToolWindow.TitleActions"
           class="com.intellij.agent.workbench.sessions.actions.DumbAwareDefaultActionGroup">
      <action
        id="AgentWorkbenchSessions.ToolWindow.CreateTaskFolder"
        icon="AllIcons.Actions.NewFolder"
        class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsToolWindowCreateTaskFolderAction"/>
    </group>
    <group
      id="AgentWorkbenchSessions.MainToolbar.Activity"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsMainToolbarActivityGroup">
      <add-to-group group-id="MainToolbarLeft" anchor="after" relative-to-action="MainToolbarVCSGroup"/>
    </group>
    <action
      id="AgentWorkbenchSessions.TreePopup.Open"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupOpenAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.More"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupMoreAction"/>
    <group
      id="AgentWorkbenchSessions.TreePopup.NewThread"
      popup="true"
      icon="AllIcons.General.Add"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupNewThreadGroup"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.CreateTaskFolder"
      icon="AllIcons.Actions.NewFolder"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupCreateTaskFolderAction"/>
    <group
      id="AgentWorkbenchSessions.TreePopup.TaskFolderAgent"
      popup="true"
      icon="AllIcons.General.Add"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupTaskFolderAgentGroup"/>
    <group
      id="AgentWorkbenchSessions.TreePopup.MoveToTaskFolder"
      popup="true"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupMoveToTaskFolderGroup"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.RemoveFromTaskFolder"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupRemoveFromTaskFolderAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.MarkTaskFolderDone"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupMarkTaskFolderDoneAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.RenameTaskFolder"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupRenameTaskFolderAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.DeleteTaskFolder"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupDeleteTaskFolderAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.SetTaskFolderMetadata"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupSetTaskFolderMetadataAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.DeleteTaskFolderMetadata"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupDeleteTaskFolderMetadataAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.Rename"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupRenameThreadAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.TogglePin"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupToggleThreadPinAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.CopyThreadId"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupCopyThreadIdAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.Archive"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupArchiveThreadAction"/>
    <action
      id="AgentWorkbenchSessions.TreePopup.Unarchive"
      class="com.intellij.agent.workbench.sessions.toolwindow.actions.AgentSessionsTreePopupUnarchiveThreadAction"/>
    <group id="AgentWorkbenchSessions.TreePopup" class="com.intellij.agent.workbench.sessions.actions.DumbAwareDefaultActionGroup">
      <reference ref="AgentWorkbenchSessions.TreePopup.Open"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.More"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.NewThread"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.CreateTaskFolder"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.TaskFolderAgent"/>
      <separator/>
      <reference ref="AgentWorkbenchSessions.TreePopup.MoveToTaskFolder"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.RemoveFromTaskFolder"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.MarkTaskFolderDone"/>
      <separator/>
      <reference ref="AgentWorkbenchSessions.TreePopup.RenameTaskFolder"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.SetTaskFolderMetadata"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.DeleteTaskFolderMetadata"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.DeleteTaskFolder"/>
      <separator/>
      <reference ref="AgentWorkbenchSessions.TreePopup.Archive"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.Unarchive"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.Rename"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.TogglePin"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.CopyThreadId"/>
      <reference ref="CopyReferencePopupGroup"/>
    </group>
    <group id="AgentWorkbenchSessions.TreePopup.EmptyArea" class="com.intellij.agent.workbench.sessions.actions.DumbAwareDefaultActionGroup">
      <reference ref="AgentWorkbenchSessions.TreePopup.NewThread"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.CreateTaskFolder"/>
      <reference ref="AgentWorkbenchSessions.TreePopup.TaskFolderAgent"/>
    </group>
  </actions>
</idea-plugin>
