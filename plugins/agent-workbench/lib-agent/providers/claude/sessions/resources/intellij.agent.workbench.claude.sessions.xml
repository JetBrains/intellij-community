<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.agent.workbench.claude.common"/>
    <module name="intellij.agent.workbench.cli"/>
    <module name="intellij.agent.workbench.common"/>
    <module name="intellij.agent.workbench.core"/>
    <module name="intellij.agent.workbench.filewatch"/>
    <module name="intellij.agent.workbench.json"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.agent.workbench.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="agentWorkbenchClaude"
      implementation="com.intellij.agent.workbench.claude.sessions.ClaudeAgentSessionProviderDescriptor"/>
    <httpRequestHandler implementation="com.intellij.agent.workbench.claude.sessions.ClaudeHookHttpRequestHandler"/>
    <agent.workbench.mcpConfigProviderContributor
      implementation="com.intellij.agent.workbench.claude.sessions.ClaudeAwbMcpConfigProviderContributor"/>
  </extensions>
</idea-plugin>
