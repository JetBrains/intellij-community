<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.ai.agent.claude.common"/>
    <module name="intellij.platform.ai.agent.cli"/>
    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.platform.ai.agent.filewatch"/>
    <module name="intellij.platform.ai.agent.json"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="agentWorkbenchClaude"
      providerId="claude"
      implementation="com.intellij.platform.ai.agent.claude.sessions.ClaudeAgentSessionProviderDescriptor"/>
    <httpRequestHandler implementation="com.intellij.platform.ai.agent.claude.sessions.ClaudeHookHttpRequestHandler"/>
    <agent.workbench.mcpConfigProviderContributor
      implementation="com.intellij.platform.ai.agent.claude.sessions.ClaudeAwbMcpConfigProviderContributor"/>
  </extensions>
</idea-plugin>
