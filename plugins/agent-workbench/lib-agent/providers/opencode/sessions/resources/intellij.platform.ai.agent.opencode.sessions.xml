<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="org.jetbrains.plugins.terminal"/>
    <module name="intellij.platform.ai.agent.cli"/>
    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.platform.ai.agent.json"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
    <module name="intellij.terminal.backend"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="opencode"
      order="after pi, before terminal"
      implementation="com.intellij.platform.ai.agent.opencode.sessions.OpenCodeAgentSessionProviderDescriptor"/>
    <agent.workbench.sessionLaunchContributor implementation="com.intellij.platform.ai.agent.opencode.sessions.OpenCodeMcpUrlLaunchContributor"/>
  </extensions>
</idea-plugin>
