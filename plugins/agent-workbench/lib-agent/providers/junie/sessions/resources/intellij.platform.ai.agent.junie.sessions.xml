<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.platform.ai.agent.filewatch"/>
    <module name="intellij.platform.ai.agent.json"/>
    <module name="intellij.platform.ai.agent.junie.common"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="junie"
      order="after claude"
      implementation="com.intellij.platform.ai.agent.junie.sessions.JunieAgentSessionProviderDescriptor"/>
    <agent.workbench.sessionLaunchContributor
      implementation="com.intellij.platform.ai.agent.junie.sessions.JunieAwbMcpLocationContributor"/>
  </extensions>
</idea-plugin>
