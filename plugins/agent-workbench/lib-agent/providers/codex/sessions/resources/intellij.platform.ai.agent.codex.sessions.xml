<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.ai.agent.codex.common"/>
    <module name="intellij.platform.ai.agent.common"/>
    <module name="intellij.platform.ai.agent.core"/>
    <module name="intellij.platform.ai.agent.filewatch"/>
    <module name="intellij.platform.ai.agent.json"/>
    <module name="intellij.agent.workbench.prompt.core"/>
    <module name="intellij.platform.ai.agent.sessions.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <agent.workbench.sessionProvider
      id="codex"
      order="before claude"
      implementation="com.intellij.platform.ai.agent.codex.sessions.CodexAgentSessionProviderDescriptor"/>
    <agent.workbench.mcpConfigProviderContributor
      implementation="com.intellij.platform.ai.agent.codex.sessions.CodexAwbMcpConfigProviderContributor"/>
    <agent.workbench.sessionLaunchContributor
      implementation="com.intellij.platform.ai.agent.codex.sessions.CodexMcpConfigLaunchContributor"/>
  </extensions>

</idea-plugin>
