  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.canBeSelectedInProjectPaneProvider"
                    interface="com.intellij.ide.projectView.impl.canBeSelected.CanBeSelectedInProjectPaneProvider"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.scratchLanguageFilter"
                    interface="com.intellij.ide.scratch.ScratchFileTypeFilter"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.usageInfoFilter"
                    interface="com.intellij.find.impl.UsageInfoAdapterFilter"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.runInspectionDialogExtension"
                    interface="com.intellij.codeInspection.actions.RunInspectionDialogExtension"
                    dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <canBeSelectedInProjectPaneProvider
      implementation="com.intellij.ide.projectView.impl.canBeSelected.SourceOrLibraryCanBeSelectedInProjectPaneProvider"/>
    <canBeSelectedInProjectPaneProvider
      implementation="com.intellij.ide.projectView.impl.canBeSelected.ArchiveCanBeSelectedInProjectPaneProvider"/>
    <canBeSelectedInProjectPaneProvider
      implementation="com.intellij.ide.projectView.impl.canBeSelected.ScratchCanBeSelectedInProjectPaneProvider"/>

    <completion.frontendFriendlyPrefixMatcher target="com.intellij.codeInsight.completion.command.LimitedToleranceMatcher"
                                              converter="com.intellij.codeInsight.completion.command.LimitedToleranceMatcher$Converter"
                                              descriptor="com.intellij.codeInsight.completion.command.LimitedToleranceMatcher$Descriptor"/>

    <completion.frontendFriendlyPrefixMatcher target="com.intellij.codeInsight.completion.impl.BetterPrefixMatcher"
                                              converter="com.intellij.codeInsight.completion.impl.BetterPrefixMatcher$Converter"
                                              descriptor="com.intellij.codeInsight.completion.impl.BetterPrefixMatcher$Descriptor"/>

    <completion.frontendFriendlyPrefixMatcher target="com.intellij.codeInsight.completion.impl.BetterPrefixMatcher$AutoRestarting"
                                              converter="com.intellij.codeInsight.completion.impl.BetterPrefixMatcher$AutoRestarting$Converter"
                                              descriptor="com.intellij.codeInsight.completion.impl.BetterPrefixMatcher$AutoRestarting$Descriptor"/>

    <applicationService serviceImplementation="com.intellij.codeInsight.completion.command.configuration.ApplicationCommandCompletionService"/>
    <applicationSettings service="com.intellij.codeInsight.completion.command.configuration.ApplicationCommandCompletionService"/>
    <vetoRenameCondition implementation="com.intellij.openapi.paths.WebReferenceVetoRenameCondition"/>

    <projectSettings service="com.intellij.analysis.AnalysisUIOptions"/>
    <projectSettings service="com.intellij.codeInsight.actions.onSave.CodeCleanupOnSaveOptions"/>
    <projectSettings service="com.intellij.codeInsight.actions.onSave.OptimizeImportsOnSaveOptions"/>
    <projectSettings service="com.intellij.codeInsight.actions.onSave.FormatOnSaveOptions"/>
    <projectSettings service="com.intellij.tools.ToolsProjectConfig"/>
    <projectSettings service="com.intellij.codeInspection.ex.ProjectInspectionProfilesVisibleTreeState"/>
    <projectSettings service="com.intellij.ide.actions.runAnything.RunAnythingCache"/>
    <projectSettings service="com.intellij.slicer.SliceManager"/>
    <projectSettings service="com.intellij.slicer.SliceToolwindowSettings"/>
    <projectSettings service="com.intellij.psi.templateLanguages.TemplateDataLanguageMappings"/>
    <projectSettings service="com.intellij.moduleDependencies.DependenciesAnalyzeManager"/>
    <projectSettings service="com.intellij.framework.detection.impl.exclude.old.OldFacetDetectionExcludesConfiguration"/>
    <projectSettings service="com.intellij.codeInsight.CodeInsightWorkspaceSettings"/>
    <projectSettings service="com.intellij.codeEditor.printing.ExportToHTMLSettings"/>
    <applicationSettings service="com.intellij.ide.util.gotoByName.SearchEverywhereConfiguration"/>
    <projectSettings service="com.intellij.ide.util.gotoByName.GotoClassSymbolConfiguration"/>
    <projectSettings service="com.intellij.ide.util.gotoByName.GotoFileConfiguration"/>
    <projectSettings service="com.intellij.codeInsight.hints.codeVision.CodeVisionProjectSettings"/>
    <applicationSettings service="com.intellij.find.actions.SearchOptionsService"/>
    <projectSettings service="com.intellij.ide.actions.runAnything.RunAnythingContextRecentDirectoryCache"/>
    <projectSettings service="com.intellij.find.findInProject.FindInProjectScopeService"/>
    <projectSettings service="com.intellij.refactoring.rename.RenameScopeService"/>
    <applicationSettings service="com.intellij.refactoring.rename.impl.TextOptionsService"/>
    <applicationSettings service="com.intellij.ide.actions.searcheverywhere.footer.ActionHistoryManager"/>
    <applicationSettings service="com.intellij.openapi.projectRoots.impl.jdkDownloader.JdkInstallerStore"/>
    <projectSettings service="com.intellij.analysis.problemsView.toolWindow.ProblemsViewStateManager"/>
    <projectSettings service="com.intellij.ui.tabs.PerUserFileColorModelStorageManager"/>
    <projectSettings service="com.intellij.ui.tabs.PerTeamFileColorModelStorageManager"/>
    <applicationSettings service="com.intellij.codeInsight.hints.chain.DeclarativeCallChainInlaySettings"/>
    <registryKey key="hyperlink.ide.decompiler.open.file" defaultValue="true" description="Load binary files in hyperlink on background thread"/>
    <registryKey key="project.structure.source.roots.editable.limit" defaultValue="20"
                 description="Maximum number of source roots under a content root to be editable"/>
