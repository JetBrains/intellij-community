<idea-plugin visibility="public">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.backend"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.impl"/>
    <module name="intellij.platform.ide"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.ide.impl"/>
    <module name="intellij.platform.indexing"/>
    <module name="intellij.platform.lang"/>
    <module name="intellij.platform.lang.impl"/>
    <module name="intellij.platform.projectModel"/>
    <module name="intellij.platform.util.ex"/>
  </dependencies>
  <!-- endregion -->
  
  <extensionPoints>
    <extensionPoint name="projectIndexesWarmupSupport" interface="com.intellij.warmup.ProjectIndexesWarmupSupport" area="IDEA_PROJECT"/>
    <extensionPoint name="projectBuildWarmupSupport" interface="com.intellij.warmup.ProjectBuildWarmupSupport" area="IDEA_PROJECT"/>
  </extensionPoints>
  <extensions defaultExtensionNs="com.intellij">
    <appStarter id="warmup" implementation="com.intellij.warmup.ProjectCachesWarmup"/>
    <projectBuildWarmupSupport implementation="com.intellij.warmup.PlatformBuildWarmupSupport"/>
  </extensions>

</idea-plugin>