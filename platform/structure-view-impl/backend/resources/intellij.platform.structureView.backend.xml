<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="fleet.rhizomedb"/>
    <module name="intellij.platform.analysis"/>
    <module name="intellij.platform.backend"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.ui"/>
    <module name="intellij.platform.editor.ui"/>
    <module name="intellij.platform.ide"/>
    <module name="intellij.platform.ide.concurrency"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.ide.impl"/>
    <module name="intellij.platform.kernel"/>
    <module name="intellij.platform.lang"/>
    <module name="intellij.platform.lang.impl"/>
    <module name="intellij.platform.rpc.backend"/>
    <module name="intellij.platform.rpc.topics"/>
    <module name="intellij.platform.statistics"/>
    <module name="intellij.platform.structureView"/>
    <module name="intellij.platform.util.ui"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <platform.rpc.backend.remoteApiProvider implementation="com.intellij.platform.structureView.backend.StructureTreeApiProvider"/>
    <applicationService serviceImplementation="com.intellij.platform.structureView.backend.BackendStructureTreeService" client="all"/>
    <codeInsight.completion.command.provider language="JAVA" implementationClass="com.intellij.platform.structureView.backend.completion.commands.ViewStructureCompletionCommandProvider" order="last"/>
  </extensions>
</idea-plugin>