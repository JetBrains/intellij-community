<idea-plugin visibility="public">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.libraries.fastutil"/>
    <module name="intellij.libraries.kotlinx.collections.immutable"/>
    <module name="intellij.platform.analysis"/>
    <module name="intellij.platform.analysis.impl"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.impl"/>
    <module name="intellij.platform.core.ui"/>
    <module name="intellij.platform.diff"/>
    <module name="intellij.platform.diff.impl"/>
    <module name="intellij.platform.editor.ui"/>
    <module name="intellij.platform.execution"/>
    <module name="intellij.platform.execution.impl"/>
    <module name="intellij.platform.ide"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.ide.impl"/>
    <module name="intellij.platform.lang.core"/>
    <module name="intellij.platform.lang.impl"/>
    <module name="intellij.platform.projectModel"/>
    <module name="intellij.platform.testIntegration"/>
    <module name="intellij.platform.util.ui"/>
  </dependencies>
  <!-- endregion -->

  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.testFramework"
                    interface="com.intellij.testIntegration.TestFramework"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.testStatusListener"
                    interface="com.intellij.execution.testframework.TestStatusListener"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.testActionProvider"
                    interface="com.intellij.execution.testframework.ToggleModelActionProvider"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.testDiffProvider"
                    beanClass="com.intellij.lang.LanguageExtensionPoint"
                    dynamic="true">
      <with attribute="implementationClass" implements="com.intellij.execution.testframework.actions.TestDiffProvider"/>
    </extensionPoint>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <actionPromoter implementation="com.intellij.execution.testframework.TestTreeViewActionsPromoter"/>
    <iconProvider implementation="com.intellij.execution.testframework.TestIconProvider" id="testIcons"/>
    <notificationGroup id="Test Runner" displayType="NONE" bundle="messages.TestRunnerBundle" key="notification.group.test.runner"/>
    <projectService serviceImplementation="com.intellij.execution.testframework.export.ExportTestResultsConfiguration"/>
    <projectSettings service="com.intellij.execution.testframework.autotest.AutoTestManager"/>
    <projectSettings service="com.intellij.execution.testframework.export.ExportTestResultsConfiguration"/>
  </extensions>

  <actions resource-bundle="messages.ActionsBundle">
    <group id="TestTreePopupMenu">
      <!--suppress PluginXmlCapitalization -->
      <action id="openAssertEqualsDiff" class="com.intellij.execution.testframework.actions.ViewAssertEqualsDiffAction" use-shortcut-of="Diff.ShowDiff"/>
      <separator/>
      <reference ref="RunContextGroup"/>
      <reference ref="EditSource"/>
    </group>

    <action id="ExportTestResults" class="com.intellij.execution.testframework.export.ExportTestResultsAction"
            icon="AllIcons.ToolbarDecorator.Export"/>
    <action id="RerunFailedTests" class="com.intellij.execution.testframework.actions.RerunFailedTestsAction"
            icon="AllIcons.RunConfigurations.RerunFailedTests"/>
  </actions>
</idea-plugin>