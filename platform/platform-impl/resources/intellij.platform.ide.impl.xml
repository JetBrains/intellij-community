  <!-- endregion -->
  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.editor.interLineBreakpointConfigurationProvider"
                    interface="com.intellij.openapi.editor.impl.InterLineBreakpointConfigurationProvider"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.editorEmptyTextPromotedActionProvider"
                    interface="com.intellij.openapi.fileEditor.impl.EditorEmptyTextPromotedActionProvider"
                    dynamic="true"/>
    <extensionPoint name="imageReaderWriterSpi"
                    beanClass="com.intellij.util.imageio.ImageReaderWriterSpiBean"
                    dynamic="true">
      <with attribute="implementationClass" implements="javax.imageio.spi.IIOServiceProvider"/>
    </extensionPoint>
  </extensionPoints>
  <extensions defaultExtensionNs="com.intellij">
    <ApplicationLoadListener implementation="com.intellij.util.imageio.ImageReaderWriterSpiRegistrar"/>
    <applicationActivity implementation="com.intellij.ide.debug.ImageDebugUtilLoader"/>
    <applicationService serviceImplementation="com.intellij.ui.WaylandAppIconPatcher"
                        preload="notHeadless"
                        os="linux"/>
    <registryKey
      key="universal.file.chooser.is.enabled"
      defaultValue="true"
      description="Enable the universal file chooser dialog"
    />
    <registryKey
      key="ide.hide.default.project.directory.for.isolated.workspace"
      defaultValue="true"
      description="Hide the 'Default project directory' setting for projects in an isolated environment (Docker containers/devcontainers, SSH, remote dev)"
    />
    <registryKey
      key="ide.project.frame.auto.fix.size.windows.interval"
      defaultValue="60"
      description="The interval between too-small window size checks on Windows and attempts to restore the size. Set to zero to disable"
    />
    <registryKey
      key="ide.windows.main.menu.focus.on.alt"
      defaultValue="true"
      description="Enable Alt key to focus the main menu bar on Windows"
      restartRequired="true"
    />
    <registryKey
      key="ea.diagnostic.endpoint"
      defaultValue=""
      description="Custom ITN error reporting endpoint. Only HTTPS URLs whose host ends with .jetbrains.com are accepted"
    />
    <registryKey
      key="ea.diagnostic.endpoint.public.key"
      defaultValue=""
      description="Pinned public key for the ITN error reporting endpoint. Required when ea.diagnostic.endpoint is set. Accepts Base64-encoded SubjectPublicKeyInfo bytes or PEM text"
    />
    <registryKey
      key="ea.auto.report.feature.visible"
      defaultValue="true"
      description="Makes the automatic error reporting feature visible in UI and available to enable/disable"
      restartRequired="true"/>
    <registryKey
      key="ea.auto.report.forced" defaultValue="none"
      description="Forces the automatic error reporting feature to be enabled with a certain level. Values: all | freezes | none"
      restartRequired="true"/>
    <registryKey
      key="ea.auto.report.forced.tag" defaultValue=""
      description="Additional tag for error reports"/>
    <registryKey
      key="ide.linux.ijpl43505"
      defaultValue="true"
      description="Enable the fix for IJPL-43505 Window header disappears after opening more than one project"
      restartRequired="true"
    />
    <registryKey
      key="ide.ui.keymap.ijpl187594"
      defaultValue="true"
      description="Enable the fix for IJPL-187594 Keymaps: shortcuts overlap long action names. The Classic UI is not affected"
    />

    <statistics.counterUsagesCollector implementationClass="com.intellij.platform.ide.menu.MainMenuCollector"/>
    <statistics.counterUsagesCollector implementationClass="com.intellij.ide.minimap.MinimapUsageCollector"/>
    <projectSettings service="com.intellij.openapi.updateSettings.impl.pluginsAdvertisement.UnknownFeaturesCollector"/>
    <projectSettings service="com.intellij.ui.RecentsManager"/>
    <projectSettings service="com.intellij.ide.errorTreeView.impl.ErrorTreeViewConfiguration"/>
    <applicationSettings service="com.intellij.execution.wsl.WSLDistributionService"/>
    <applicationSettings service="com.intellij.util.singleProduct.MigrationToSingleProductSettings"/>
    <projectSettings service="com.intellij.openapi.project.impl.ProjectRootPersistentStateComponent"/>
    <projectSettings service="com.intellij.ide.ProjectColorInfoManager"/>
    <projectSettings service="com.intellij.platform.OpenProjectSettingsService"/>
    <applicationSettings service="com.intellij.diagnostic.ExceptionEAPAutoReportManager"/>
    <applicationSettings service="com.intellij.diagnostic.logs.LogLevelConfigurationManager"/>
    <projectSettings service="com.intellij.openapi.fileEditor.impl.EditorHistoryManager"/>
    <applicationSettings service="com.intellij.toolWindow.ButtonsStateService"/>
    <applicationSettings service="com.intellij.toolWindow.ToolWindowDefaultLayoutManager"/>
    <applicationSettings service="com.intellij.toolWindow.xNext.toolbar.data.XNextPinnedService"/>
    <applicationSettings service="com.intellij.notification.impl.RemindLaterManager"/>
    <applicationSettings service="com.intellij.ide.plugins.org.PluginManagerConfigurableForOrgConfig"/>
  </extensions>
</idea-plugin>
