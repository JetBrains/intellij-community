            </constraints>
            <properties>
              <text resource-bundle="messages/ApplicationBundle" key="label.found.unused"/>
            </properties>
          </component>
          <vspacer id="2deda">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="1" anchor="0" fill="0" indent="0" use-parent-layout="false">
                <preferred-size width="-1" height="10"/>
              </grid>
            </constraints>
          </vspacer>
          <grid id="7996" binding="myTableUIPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="1" use-parent-layout="false"/>
