            <properties/>
            <border type="none"/>
            <children/>
          </grid>
          <vspacer id="363d7">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="1" anchor="0" fill="0" indent="0" use-parent-layout="false">
                <preferred-size width="-1" height="10"/>
              </grid>
            </constraints>
          </vspacer>
          <vspacer id="65078">
            <constraints>
