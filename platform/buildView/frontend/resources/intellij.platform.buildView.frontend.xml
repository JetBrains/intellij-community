<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.frontend"/>
    <module name="intellij.platform.buildView"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.ui"/>
    <module name="intellij.platform.execution"/>
    <module name="intellij.platform.execution.impl"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.ide.impl"/>
    <module name="intellij.platform.lang"/>
    <module name="intellij.platform.lang.impl"/>
    <module name="intellij.platform.util.coroutines"/>
    <module name="intellij.platform.util.ui"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <frontend.splitComponentProvider implementation="com.intellij.platform.buildView.frontend.BuildTreeComponentProvider"/>
    <postStartupActivity implementation="com.intellij.platform.buildView.frontend.FrontendBuildViewStartupActivity"/>
  </extensions>
  <actions resource-bundle="messages.LangBundle">
    <group id="BuildViewToolbar">
      <reference ref="BuildView"/>
      <action id="PinBuildView" class="com.intellij.platform.buildView.frontend.PinBuildViewAction" icon="AllIcons.General.Pin_tab"/>
      <group id="BuildViewFiltering" popup="true" icon="AllIcons.Actions.Show">
        <action id="BuildViewFilterWarnings" class="com.intellij.platform.buildView.frontend.BuildViewFilterWarningsAction"/>
        <action id="BuildViewFilterSuccessful" class="com.intellij.platform.buildView.frontend.BuildViewFilterSuccessfulAction"/>
      </group>
    </group>
  </actions>
</idea-plugin>
