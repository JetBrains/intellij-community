<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="fleet.rhizomedb"/>
    <module name="intellij.libraries.kotlinx.coroutines.core"/>
    <module name="intellij.platform.analysis"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.ui"/>
    <module name="intellij.platform.editor.ui"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.ide.core.plugins"/>
    <module name="intellij.platform.kernel"/>
    <module name="intellij.platform.projectModel"/>
    <module name="intellij.platform.util.coroutines"/>
    <module name="intellij.platform.util.ex"/>
    <module name="intellij.platform.util.ui"/>
  </dependencies>
  <!-- endregion -->
  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.runContentManagerExtension"
                    interface="com.intellij.execution.ui.RunContentManagerExtension" dynamic="true"/>
  </extensionPoints>
  <extensions defaultExtensionNs="com.intellij">
    <projectSettings service="com.intellij.diagnostic.logging.LogConsolePreferences"/>
    <projectSettings service="com.intellij.execution.target.TargetEnvironmentsManager"/>
  </extensions>
</idea-plugin>