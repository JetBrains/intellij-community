<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.platform.backend"/>
    <module name="intellij.platform.kernel.backend"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.ui"/>
    <module name="intellij.platform.ide"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.ide.nonModalWelcomeScreen"/>
    <module name="intellij.platform.rpc.backend"/>
  </dependencies>
  <!-- endregion -->

  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.platform.ide.welcomeScreenFeatureBackend"
                    interface="com.intellij.platform.ide.nonModalWelcomeScreen.backend.WelcomeScreenFeatureBackend" dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <platform.rpc.backend.remoteApiProvider implementation="com.intellij.platform.ide.nonModalWelcomeScreen.backend.BackendWelcomeScreenFeatureApiProvider"/>
  </extensions>
</idea-plugin>
