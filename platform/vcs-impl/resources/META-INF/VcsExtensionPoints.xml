<idea-plugin>
  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.checkoutProvider"
                    interface="com.intellij.openapi.vcs.CheckoutProvider"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcs.checkoutProcessor"
                    interface="com.intellij.openapi.vcs.VcsCheckoutProcessor"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcsRootChecker"
                    interface="com.intellij.openapi.vcs.VcsRootChecker"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcsRootErrorFilter"
                    interface="com.intellij.openapi.vcs.VcsRootErrorFilter"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcsIgnoreChecker"
                    interface="com.intellij.openapi.vcs.VcsIgnoreChecker"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcs"
                    beanClass="com.intellij.openapi.vcs.impl.VcsEP"
                    dynamic="true">
      <with attribute="vcsClass" implements="com.intellij.openapi.vcs.AbstractVcs"/>
    </extensionPoint>

    <extensionPoint qualifiedName="com.intellij.unresolvedMergeCheckProvider"
                    interface="com.intellij.openapi.vcs.checkin.UnresolvedMergeCheckProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.changesViewContent"
                    beanClass="com.intellij.openapi.vcs.changes.ui.ChangesViewContentEP"
                    area="IDEA_PROJECT"
                    dynamic="true">
      <with attribute="className" implements="com.intellij.openapi.vcs.changes.ui.ChangesViewContentProvider"/>
      <with attribute="predicateClassName" implements="java.util.function.Predicate"/>
      <with attribute="preloaderClassName" implements="com.intellij.openapi.vcs.changes.ui.ChangesViewContentProvider$Preloader"/>
    </extensionPoint>

    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.impl.LocalLineStatusTrackerProvider"
                    interface="com.intellij.openapi.vcs.impl.LocalLineStatusTrackerProvider"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcs.branchStateProvider"
                    interface="com.intellij.vcs.branch.BranchStateProvider"
                    area="IDEA_PROJECT"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.commitMessageProvider" interface="com.intellij.openapi.vcs.changes.ui.CommitMessageProvider" dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcs.changes.changesViewConflictsBannerCustomizer"
                    interface="com.intellij.openapi.vcs.merge.ChangesViewConflictsBannerCustomizer"
                    area="IDEA_PROJECT"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.editChangelistSupport"
                    interface="com.intellij.openapi.vcs.changes.ui.EditChangelistSupport"
                    area="IDEA_PROJECT"/>

    <extensionPoint qualifiedName="com.intellij.vcsSelectionProvider"
                    interface="com.intellij.vcsUtil.VcsSelectionProvider"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcs.changes.localCommitExecutor" interface="com.intellij.openapi.vcs.changes.CommitExecutor"
                    area="IDEA_PROJECT" dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.commitSuccessNotificationActionProvider"
                    interface="com.intellij.vcs.commit.CommitSuccessNotificationActionProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcsConfigurableProvider"
                    interface="com.intellij.openapi.vcs.VcsConfigurableProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.generalVcsSettingsExtension"
                    beanClass="com.intellij.openapi.vcs.configurable.GeneralVcsSettingsProviderEP"
                    area="IDEA_PROJECT" dynamic="true">
      <with attribute="instance" implements="com.intellij.openapi.options.UnnamedConfigurable"/>
    </extensionPoint>

    <!--<extensionPoint name="writingAccessProvider"-->
    <!--interface="com.intellij.openapi.vfs.WritingAccessProvider"-->
    <!--area="IDEA_PROJECT"/>-->

    <extensionPoint qualifiedName="com.intellij.vcs.fileStatusProvider"
                    interface="com.intellij.openapi.vcs.impl.FileStatusProvider"
                    area="IDEA_PROJECT"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.baseContentProvider"
                    interface="com.intellij.openapi.vcs.impl.VcsBaseContentProvider"
                    area="IDEA_PROJECT"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.ignoredFilesHolder"
                    interface="com.intellij.openapi.vcs.changes.VcsManagedFilesHolder$Provider"
                    area="IDEA_PROJECT"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.unversionedFilesHolder"
                    interface="com.intellij.openapi.vcs.changes.VcsManagedFilesHolder$Provider"
                    area="IDEA_PROJECT"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.resolvedConflictsFilesHolder"
                    interface="com.intellij.openapi.vcs.changes.VcsManagedFilesHolder$Provider"
                    area="IDEA_PROJECT"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcs.pathsToRefreshProvider"
                    interface="com.intellij.vcs.commit.VcsPathsToRefreshProvider"
                    area="IDEA_PROJECT"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcsPopupProvider"
                    interface="com.intellij.openapi.vcs.actions.VcsQuickListContentProvider"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.patch.extension"
                    interface="com.intellij.openapi.diff.impl.patch.PatchEP"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcsChangesViewRefresher"
                    interface="com.intellij.openapi.vcs.changes.ChangesViewRefresher"
                    area="IDEA_PROJECT"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcsAnnotationGutterActionProvider"
                    interface="com.intellij.openapi.vcs.annotate.AnnotationGutterActionProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcsAnnotationGutterColumnProvider"
                    interface="com.intellij.openapi.vcs.annotate.AnnotationGutterColumnProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.taskHandler"
                    interface="com.intellij.openapi.vcs.VcsTaskHandler"
                    area="IDEA_PROJECT"
                    dynamic="true"/>

    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.changes.actions.diff.ChangeDiffRequestProvider"
                    interface="com.intellij.openapi.vcs.changes.actions.diff.ChangeDiffRequestProvider"
                    dynamic="true"/>
    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.changes.actions.diff.ChangeDiffViewerWrapperProvider"
                    interface="com.intellij.openapi.vcs.changes.actions.diff.ChangeDiffViewerWrapperProvider"
                    dynamic="true"/>

    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.actions.AnnotateToggleAction.Provider"
                    interface="com.intellij.openapi.vcs.actions.AnnotateToggleAction$Provider" dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.ignoredFileProvider"
                    dynamic="true"
                    interface="com.intellij.openapi.vcs.changes.IgnoredFileProvider"/>
    <extensionPoint qualifiedName="com.intellij.ignoredFileContentProvider"
                    dynamic="true"
                    interface="com.intellij.openapi.vcs.changes.IgnoredFileContentProvider" area="IDEA_PROJECT"/>

    <extensionPoint qualifiedName="com.intellij.vcsSharedChecker"
                    dynamic="true"
                    interface="com.intellij.openapi.vcs.VcsSharedChecker" area="IDEA_PROJECT"/>

    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.history.actions.ShowDiffBeforeWithLocalAction.ExtensionProvider"
                    interface="com.intellij.openapi.actionSystem.AnActionExtensionProvider"
                    dynamic="true"/>
    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.history.actions.ShowDiffAfterWithLocalAction.ExtensionProvider"
                    interface="com.intellij.openapi.actionSystem.AnActionExtensionProvider"
                    dynamic="true"/>
    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.changes.actions.CreatePatchFromChangesAction.Dialog.ExtensionProvider"
                    interface="com.intellij.openapi.actionSystem.AnActionExtensionProvider"
                    dynamic="true"/>
    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.changes.actions.CreatePatchFromChangesAction.Clipboard.ExtensionProvider"
                    interface="com.intellij.openapi.actionSystem.AnActionExtensionProvider"
                    dynamic="true"/>
    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.history.actions.GetVersionAction.ExtensionProvider"
                    interface="com.intellij.openapi.actionSystem.AnActionExtensionProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcsRepositoryInitializer"
                    interface="com.intellij.vcs.VcsRepositoryInitializer"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.changes.vcsPreservingExecutor"
                    interface="com.intellij.openapi.vcs.changes.VcsPreservingExecutor"
                    dynamic="true"/>
    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.ui.cloneDialog.VcsCloneDialogExtension"
                    interface="com.intellij.openapi.vcs.ui.cloneDialog.VcsCloneDialogExtension"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.ui.commitOptionsDialogExtension"
                    interface="com.intellij.openapi.vcs.ui.CommitOptionsDialogExtension"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.openapi.vcs.changes.ui.shareProjectAction"
                    interface="com.intellij.openapi.vcs.changes.ui.ShareProjectActionProvider"
                    dynamic="true"/>

    <!--suppress PluginXmlValidity -->
    <extensionPoint qualifiedName="com.intellij.vcs.actions.ScheduleForAdditionActionExtension"
                    interface="com.intellij.openapi.vcs.changes.actions.ScheduleForAdditionActionExtension"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcsStartupActivity" interface="com.intellij.openapi.vcs.impl.VcsStartupActivity" dynamic="false"/>

    <extensionPoint qualifiedName="com.intellij.vcsBulkMovesOnlyChangesFilter"
                    interface="com.intellij.openapi.vcs.changes.ui.browser.BulkMovesOnlyChangesFilter"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.consoleFolding"
                    interface="com.intellij.vcs.console.VcsConsoleFolding"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.changeListChangeAssigner"
                    interface="com.intellij.openapi.vcs.changes.ChangeListChangeAssigner"
                    area="IDEA_PROJECT"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.lineStatusClientIdRenderer"
                    interface="com.intellij.openapi.vcs.ex.LineStatusClientIdRenderer"
                    area="IDEA_PROJECT"
                    dynamic="false"/>

    <extensionPoint qualifiedName="com.intellij.vcs.envCustomizer"
                    interface="com.intellij.openapi.vcs.VcsEnvCustomizer"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.vcsSymlinkResolver"
                    interface="com.intellij.vcs.VcsSymlinkResolver"
                    area="IDEA_PROJECT"
                    dynamic="false"/>

    <extensionPoint qualifiedName="com.intellij.vcs.codeVisionLanguageContext" beanClass="com.intellij.lang.LanguageExtensionPoint" dynamic="true">
      <with attribute="implementationClass" implements="com.intellij.codeInsight.hints.VcsCodeVisionLanguageContext"/>
    </extensionPoint>

    <extensionPoint qualifiedName="com.intellij.vcs.defaultCommitMessagePolicy" interface="com.intellij.vcs.commit.DefaultCommitMessagePolicy" dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.vcs.changeListClassifierProvider" interface="com.intellij.vcs.commit.ChangeListClassifierProvider" dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.shelveSilentlyTitleProvider"
                    interface="com.intellij.openapi.vcs.changes.shelf.ShelveSilentlyTitleProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.shelveSilentlyGotItTooltipProvider"
                    interface="com.intellij.openapi.vcs.changes.shelf.ShelveSilentlyGotItTooltipProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.diffRevisionMetadataProvider"
                    interface="com.intellij.openapi.diff.impl.DiffRevisionMetadataProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.fileListenerIgnoredFilesProvider"
                    interface="com.intellij.openapi.vcs.VcsFileListenerIgnoredFilesProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.commitMessageInspection"
                    beanClass="com.intellij.vcs.commit.message.CommitMessageInspectionEP"
                    dynamic="true">
      <with attribute="implementation" implements="com.intellij.vcs.commit.message.BaseCommitMessageInspection"/>
    </extensionPoint>

    <extensionPoint qualifiedName="com.intellij.vcs.issueDocumentationTargetProvider"
                    interface="com.intellij.openapi.vcs.IssueDocumentationTargetProvider"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.impl.backend.treeNodeConverter"
                    interface="com.intellij.vcs.shelf.NodeToEntityConverter"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.impl.changeListDiffViewerDecorator"
                    interface="com.intellij.openapi.vcs.changes.actions.diff.lst.ChangeListDiffViewerDecorator"
                    dynamic="true"/>

    <extensionPoint qualifiedName="com.intellij.vcs.updateOptionsDialogProvider"
                    interface="com.intellij.openapi.vcs.update.UpdateOptionsDialogProvider"
                    dynamic="true"/>
  </extensionPoints>
</idea-plugin>
