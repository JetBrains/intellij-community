<idea-plugin>
  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.ijent.deploymentListener" interface="com.intellij.platform.ijent.spi.IjentDeploymentListener"
                    dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService
      serviceInterface="com.intellij.platform.ijent.spi.IjentSessionProvider" open="true"
      serviceImplementation="com.intellij.platform.ijent.spi.DefaultIjentSessionProvider"/>

    <applicationService
      serviceInterface="com.intellij.platform.ijent.IjentExecFileProvider" open="true"
      serviceImplementation="com.intellij.platform.ijent.DefaultIjentExecFileProvider"/>

    <registryKey defaultValue="true" description="Make ijent nio operations cancellable" key="ijent.nio.cancellable.read"/>

  </extensions>
</idea-plugin>