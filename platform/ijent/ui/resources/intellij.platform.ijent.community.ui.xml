<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.libraries.jediterm.core"/>
    <module name="intellij.libraries.jediterm.ui"/>
    <module name="intellij.libraries.kotlinx.coroutines.core"/>
    <module name="intellij.libraries.pty4j"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.ui"/>
    <module name="intellij.platform.editor.ui"/>
    <module name="intellij.platform.eel.nioFs.impl"/>
    <module name="intellij.platform.execution"/>
    <module name="intellij.platform.execution.impl"/>
    <module name="intellij.platform.ide"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.ide.impl"/>
    <module name="intellij.platform.lang"/>
    <module name="intellij.platform.projectModel"/>
    <module name="intellij.platform.util.coroutines"/>
    <module name="intellij.platform.util.ui"/>
  </dependencies>
  <!-- endregion -->

  <actions resource-bundle="messages.IjentImplBundle">
    <group id="com.intellij.platform.ijent.impl.VerificationActions"
           internal="true">
      <action
        id="com.intellij.platform.ijent.impl.IjentLocalVerificationAction"
        class="com.intellij.platform.ijent.community.ui.actions.IjentLocalVerificationAction"
        internal="true"/>
      <action
        id="com.intellij.platform.ijent.impl.IjentDockerVerificationAction"
        class="com.intellij.platform.ijent.community.ui.actions.IjentDockerVerificationAction"
        internal="true"/>
      <action
        id="com.intellij.platform.ijent.impl.MultiRoutingFileSystemVerificationAction"
        class="com.intellij.platform.ijent.community.ui.actions.MultiRoutingFileSystemVerificationAction"
        internal="true"/>
      <action
        id="com.intellij.platform.ijent.community.ui.actions.dashboard.ShowIjentDashboardAction"
        class="com.intellij.platform.ijent.community.ui.actions.dashboard.ShowIjentDashboardAction"
        internal="true"/>
    </group>
  </actions>
  <extensionPoints>
    <extensionPoint name="ijent.dashboard.tab" interface="com.intellij.platform.ijent.community.ui.actions.dashboard.IjentDashboardTab" dynamic="true"/>
  </extensionPoints>
  <extensions defaultExtensionNs="com.intellij">
    <ijent.dashboard.tab implementation="com.intellij.platform.ijent.community.ui.actions.dashboard.IjentDashboardTabStat"/>
    <ijent.dashboard.tab implementation="com.intellij.platform.ijent.community.ui.actions.dashboard.IjentDashboardTabInfo"/>
    <ijent.dashboard.tab implementation="com.intellij.platform.ijent.community.ui.actions.dashboard.IjentDashboardTabEnvVars"/>
    <project.root.unavailable implementation="com.intellij.platform.ijent.community.ui.actions.unavailable.IjentUnavailableDialogHandler"/>
    <advancedSetting
      id="container.environments.env.var.shell.mode"
      enumClass="com.intellij.platform.ijent.community.ui.settings.LoginShellEnvVarModeProviderImpl$EnvVarShellMode"
      default="LOGIN_INTERACTIVE"
      bundle="messages.IjentImplBundle"
      visible="false"
      groupKey="advanced.settings.container.environments"
    />
    <projectConfigurable
      groupId="build"
      id="ijent.dashboard"
      key="configurable.ijent.dashboard.display.name"
      bundle="messages.IjentImplBundle"
      provider="com.intellij.platform.ijent.community.ui.settings.IjentDashboardConfigurableProvider"/>
  </extensions>
</idea-plugin>