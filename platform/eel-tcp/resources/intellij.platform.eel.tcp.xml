<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.libraries.kotlinx.coroutines.core"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.ui"/>
    <module name="intellij.platform.eel.impl"/>
    <module name="intellij.platform.ide"/>
    <module name="intellij.platform.ide.impl"/>
    <module name="intellij.platform.projectModel"/>
    <module name="intellij.platform.util.coroutines"/>
    <module name="intellij.platform.util.ex"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <multiRoutingFileSystemBackend implementation="com.intellij.platform.eel.tcp.TcpEelMrfsBackend"/>
    <eelProvider implementation="com.intellij.platform.eel.tcp.TcpEelProvider"/>
    <eelTcpPathParser implementation="com.intellij.platform.eel.tcp.raw.RawTcpPathParser"/>
    <eelMachineResolver implementation="com.intellij.platform.eel.tcp.raw.RawTcpMachineResolver"/>
  </extensions>
  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.eelTcpPathParser" interface="com.intellij.platform.eel.tcp.TcpEelPathParser"
                    dynamic="true"/>
  </extensionPoints>
</idea-plugin>
