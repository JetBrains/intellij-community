<idea-plugin visibility="public" package="com.intellij.platform.searchEverywhere">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="fleet.rhizomedb"/>
    <module name="intellij.libraries.kotlinx.coroutines.core"/>
    <module name="intellij.libraries.kotlinx.serialization.core"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.ui"/>
    <module name="intellij.platform.execution"/>
    <module name="intellij.platform.execution.impl"/>
    <module name="intellij.platform.ide"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.ide.impl"/>
    <module name="intellij.platform.lang"/>
    <module name="intellij.platform.lang.impl"/>
    <module name="intellij.platform.scopes"/>
    <module name="intellij.platform.statistics"/>
    <module name="intellij.platform.util.ui"/>
  </dependencies>
  <!-- endregion -->
  <extensionPoints>
    <extensionPoint name="searchEverywhere.itemsProviderFactory"
                    interface="com.intellij.platform.searchEverywhere.SeItemsProviderFactory"
                    dynamic="true"/>

    <extensionPoint name="searchEverywhere.legacyItemPresentationProvider"
                    interface="com.intellij.platform.searchEverywhere.SeLegacyItemPresentationProvider"
                    dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <platform.entityTypes implementation="com.intellij.platform.searchEverywhere.SeEntityTypeProvider"/>
    <remote.customDataContextSerializer implementation="com.intellij.platform.searchEverywhere.data.SeSelectedItemsDataContextSerializer" />
    <remote.customDataContextSerializer implementation="com.intellij.platform.searchEverywhere.data.SeSessionDataContextSerializer" />
    <remote.customDataContextSerializer implementation="com.intellij.platform.searchEverywhere.data.SeIsAllTabDataContextSerializer" />
  </extensions>
</idea-plugin>