<!--suppress SplitModeMixedDependencies -->
<!--suppress SplitModeImplicitModuleKind, AllContentModulesOptionalLoadingRule -->
<!--suppress PluginXmlPluginLogo, AllContentModulesOptionalLoadingRule -->
<idea-plugin>
  <id>intellij.vcs.plugin</id>
  <name>VCS</name>
  <description>Provides VCS platform modules for the IDE.</description>
  <vendor>JetBrains</vendor>
  <content namespace="jetbrains">
    <module name="intellij.platform.vcs.impl"/>
    <module name="intellij.platform.vcs.impl.exec"/>
    <module name="intellij.platform.vcs.impl.debugger"/>
    <module name="intellij.platform.vcs.impl.lang"/>
    <module name="intellij.platform.vcs.impl.lang.actions"/>
    <module name="intellij.platform.vcs.log"/>
    <module name="intellij.platform.vcs.log.impl"/>
    <!-- Keep public: this shared SQLite module is also depended on by VCS Log impl and Qodana. -->
    <module name="intellij.platform.sqlite"/>
    <!-- Required because `intellij.platform.vcs.log` is required and has a compile dependency on the graph API module. -->
    <module name="intellij.platform.vcs.log.graph"/>
    <module name="intellij.platform.vcs.log.graph.impl"/>
    <module name="intellij.platform.vcs.dvcs"/>
    <module name="intellij.platform.vcs.dvcs.impl"/>
  </content>
</idea-plugin>
