<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.libraries.opentelemetry"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.diagnostic.telemetry"/>
    <module name="intellij.platform.eel.impl"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceInterface="com.intellij.platform.eel.nioFs.impl.MultiRoutingFileSystemBackend$InitializationService"
                        serviceImplementation="com.intellij.platform.eel.nioFs.impl.EelMultiRoutingFileSystemBackendInitializationService"/>
  </extensions>
  <extensionPoints>
    <extensionPoint name="multiRoutingFileSystemBackend" interface="com.intellij.platform.eel.nioFs.impl.MultiRoutingFileSystemBackend"
                    dynamic="true"/>
  </extensionPoints>
</idea-plugin>
