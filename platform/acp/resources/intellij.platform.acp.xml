<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.libraries.kotlinx.serialization.core"/>
    <module name="intellij.platform.core"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="com.intellij">
    <applicationService
        serviceInterface="com.intellij.platform.acp.AcpAgentsCatalog"
        serviceImplementation="com.intellij.platform.acp.DefaultAcpAgentsCatalog"/>
    <projectService
        serviceInterface="com.intellij.platform.acp.AcpProcessLauncher"
        serviceImplementation="com.intellij.platform.acp.DefaultAcpProcessLauncher"/>
  </extensions>
</idea-plugin>
