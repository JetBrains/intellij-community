<idea-plugin>
  <extensions defaultExtensionNs="com.intellij">
    <applicationService
        serviceInterface="com.intellij.platform.acp.api.AcpAgentsCatalog"
        serviceImplementation="com.intellij.platform.acp.api.DefaultAcpAgentsCatalog"
        open="true"/>
    <projectService
        serviceInterface="com.intellij.platform.acp.api.AcpProcessLauncher"
        serviceImplementation="com.intellij.platform.acp.api.DefaultAcpProcessLauncher"
        open="true"/>
  </extensions>
</idea-plugin>
