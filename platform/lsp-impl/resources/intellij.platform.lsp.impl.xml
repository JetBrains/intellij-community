<idea-plugin visibility="public">
  <module value="com.intellij.modules.lsp"/>

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.libraries.gson"/>
    <module name="intellij.platform.analysis"/>
    <module name="intellij.platform.codeStyle"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.impl"/>
    <module name="intellij.platform.core.ui"/>
    <module name="intellij.platform.editor.ex"/>
    <module name="intellij.platform.editor.ui"/>
    <module name="intellij.platform.execution.impl"/>
    <module name="intellij.platform.ide"/>
    <module name="intellij.platform.ide.core"/>
    <module name="intellij.platform.ide.impl"/>
    <module name="intellij.platform.indexing"/>
    <module name="intellij.platform.lang"/>
    <module name="intellij.platform.lang.impl"/>
    <module name="intellij.platform.lsp"/>
    <module name="intellij.platform.markdown.utils"/>
    <module name="intellij.platform.projectModel"/>
    <module name="intellij.platform.statistics"/>
    <module name="intellij.platform.util.ui"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <registryKey defaultValue="100" description="LSP server connect timeout" key="lsp.server.connect.timeout"/>
    <notificationGroup id="LSP window/showMessage"
                       displayType="BALLOON"
                       bundle="messages.LspBundle"
                       key="notification.group.lsp.message"/>
    <notificationGroup id="LSP window/logMessage: errors, warnings"
                       displayType="NONE"
                       bundle="messages.LspBundle"
                       key="notification.group.lsp.log.errors.warnings"/>
    <notificationGroup id="LSP window/logMessage: info, log; $/logTrace"
                       displayType="NONE" isLogByDefault="false"
                       bundle="messages.LspBundle"
                       key="notification.group.lsp.log.info.trace"/>

    <projectService serviceInterface="com.intellij.platform.lsp.api.LspClientManager"
                    serviceImplementation="com.intellij.platform.lsp.impl.LspClientManagerImpl"/>

    <editorFactoryDocumentListener id="LspDocumentListener"
                                   implementation="com.intellij.platform.lsp.impl.platformListeners.LspDocumentListener"/>
    <vfs.asyncListener id="LspFileListener"
                       implementation="com.intellij.platform.lsp.impl.platformListeners.LspFileListener"/>

    <highlightingPassFactory implementation="com.intellij.platform.lsp.impl.features.highlighting.LspHighlightingPassFactory"/>
    <problemFileHighlightFilter implementation="com.intellij.platform.lsp.impl.features.highlighting.LspProblemFileHighlightFilter"/>
    <enterHandlerDelegate id="LspOnTypeFormattingEnterHandler" order="last"
                          implementation="com.intellij.platform.lsp.impl.features.formatter.LspOnTypeFormattingEnterHandler"/>
    <editorTypedHandler id="LspTypedActionHandler" order="last"
                        implementationClass="com.intellij.platform.lsp.impl.features.formatter.LspTypedActionHandler"/>
    <typedHandler id="LspAutoPopupTypedHandler" order="last"
                  implementation="com.intellij.platform.lsp.impl.features.completion.LspAutoPopupTypedHandler"/>
    <typedHandler id="LspParameterInfoTypedHandler" order="last, before LspAutoPopupTypedHandler"
                  implementation="com.intellij.platform.lsp.impl.features.parameterInfo.LspParameterInfoTypedHandler"/>
    <completion.contributor id="LspCompletionContributor"
                            language="any"
                            order="last, before wordCompletion, before TextMateCompletionContributor"
                            implementationClass="com.intellij.platform.lsp.impl.features.completion.LspCompletionContributor"/>
    <weigher id="LspCompletionWeigher"
             key="completion"
             order="after priority, before prefix"
             implementationClass="com.intellij.platform.lsp.impl.features.completion.LspCompletionWeigher"/>
    <codeInsight.codeVisionProvider implementation="com.intellij.platform.lsp.impl.features.codeLens.LspCodeVisionProvider"/>
    <config.codeVisionGroupSettingProvider implementation="com.intellij.platform.lsp.impl.features.codeLens.LspCodeVisionGroupSettingProvider"/>
    <codeInsight.inlayProviderFactory implementation="com.intellij.platform.lsp.impl.features.inlayCommon.LspInlayHintsProviderFactory"/>
    <codeInsight.parameterInfo id="LspParameterInfoHandler" language=""
                               implementationClass="com.intellij.platform.lsp.impl.features.parameterInfo.LspParameterInfoHandler"/>
    <psi.implicitReferenceProvider id="LspImplicitReferenceProvider"
                                   implementation="com.intellij.platform.lsp.impl.features.navigation.LspImplicitReferenceProvider"/>
    <psi.implicitReferenceProvider id="LspDocumentLinkReferenceProvider"
                                   implementation="com.intellij.platform.lsp.impl.features.navigation.LspDocumentLinkReferenceProvider"/>
    <lang.symbolTypeProvider id="LspSymbolTypeProvider" implementation="com.intellij.platform.lsp.impl.features.navigation.LspSymbolTypeProvider"/>
    <uiDataRule implementation="com.intellij.platform.lsp.impl.features.usages.LspSearchTargetsRule"/>
    <searcher forClass="com.intellij.find.usages.api.UsageSearchParameters"
              implementationClass="com.intellij.platform.lsp.impl.features.usages.LspUsageSearcher"/>
    <platform.backend.documentation.targetProvider id="LspDocumentationTargetProvider"
                                                   implementation="com.intellij.platform.lsp.impl.features.documentation.LspDocumentationTargetProvider"/>
    <formattingService id="LspFormattingService" implementation="com.intellij.platform.lsp.impl.features.formatter.LspFormattingService"/>
    <lang.importOptimizer language="" implementationClass="com.intellij.platform.lsp.impl.features.formatter.LspImportOptimizer" order="last"/>
    <lang.foldingBuilder language="" implementationClass="com.intellij.platform.lsp.impl.features.folding.LspFoldingBuilder"/>
    <gotoSymbolContributor implementation="com.intellij.platform.lsp.impl.features.workspaceSymbol.LspGoToSymbolContributor"/>
    <gotoClassContributor implementation="com.intellij.platform.lsp.impl.features.workspaceSymbol.LspGoToClassContributor"/>
    <searchEverywhereResultsEqualityProvider
      implementation="com.intellij.platform.lsp.impl.features.workspaceSymbol.LspWorkspaceSymbolEqualityProvider"/>
    <fileBreadcrumbsCollector implementation="com.intellij.platform.lsp.impl.features.documentSymbol.LspFileBreadcrumbsCollector"
                              order="last, after PsiFileBreadcrumbsCollector"/>
    <platform.lang.lsWidget.itemsProvider id="LspWidgetItemsProvider"
                                          implementation="com.intellij.platform.lsp.impl.lsWidget.LspWidgetItemsProvider"/>
    <applicationService serviceInterface="com.intellij.platform.lsp.api.lsWidget.LspWidgetInternalService"
                        serviceImplementation="com.intellij.platform.lsp.impl.lsWidget.LspWidgetInternalServiceImpl"/>
    <applicationService serviceInterface="com.intellij.platform.lsp.util.Lsp4jService"
                        serviceImplementation="com.intellij.platform.lsp.impl.util.Lsp4jServiceImpl"/>
    <highlightUsagesHandlerFactory implementation="com.intellij.platform.lsp.impl.features.highlighting.LspHighlightUsagesHandlerFactory"
                                   order="last"/>
    <registryKey key="lsp.communication.standard.log.file" defaultValue="false"
                 description="Write communication logs between the IDE and external language services to idea.log file (effective only if DEBUG-level logging is enabled for the 'com.intellij.platform.lsp' category)."/>

    <callHierarchyProvider language=""
                           implementationClass="com.intellij.platform.lsp.impl.features.hierarchy.call.LspCallHierarchyProvider"
                           order="last"/>
    <typeHierarchyProvider language=""
                           implementationClass="com.intellij.platform.lsp.impl.features.hierarchy.type.LspTypeHierarchyProvider"
                           order="last"/>
    <extendWordSelectionHandler id="LspWordSelectionHandler"
                                implementation="com.intellij.platform.lsp.impl.features.selectWord.LspWordSelectionHandler"
                                order="last"/>

    <renameHandler implementation="com.intellij.platform.lsp.impl.features.rename.LspRenameHandler" order="last"/>

    <!--@formatter:off-->
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention0</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention1</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention2</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention3</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention4</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention5</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention6</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention7</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention8</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention9</className>  <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention10</className> <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention11</className> <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention12</className> <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention13</className> <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <intentionAction> <className>com.intellij.platform.lsp.impl.features.intention.LspIntention14</className> <bundleName>messages.LspBundle</bundleName> <categoryKey>intention.group.name</categoryKey> <descriptionDirectoryName>LspIntention</descriptionDirectoryName> <language/> </intentionAction>
    <!--@formatter:on-->
  </extensions>

  <projectListeners>
    <listener topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"
              class="com.intellij.platform.lsp.impl.platformListeners.LspFileEditorManagerListener"/>
  </projectListeners>

  <applicationListeners>
    <listener topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"
              class="com.intellij.platform.lsp.impl.platformListeners.LspFileDocumentManagerListener"/>
    <listener topic="com.intellij.openapi.actionSystem.ex.AnActionListener"
              class="com.intellij.platform.lsp.impl.features.navigation.CurrentActionListener"/>
  </applicationListeners>

  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.platform.lsp.integrationProvider"
                    interface="com.intellij.platform.lsp.api.LspIntegrationProvider" dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.platform.lsp.serverSupportProvider"
                    interface="com.intellij.platform.lsp.api.LspServerSupportProvider" dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.platform.lsp.documentAdapter"
                    interface="com.intellij.platform.lsp.impl.LspDocumentAdapter"
                    dynamic="true"/>
  </extensionPoints>
</idea-plugin>