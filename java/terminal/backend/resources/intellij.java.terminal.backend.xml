<idea-plugin>
  <dependencies>
    <module name="intellij.platform.backend"/>
    <module name="intellij.java.terminal.shared"/>
    <plugin id="org.jetbrains.plugins.terminal"/>
    <module name="intellij.java.execution.impl"/>
    <module name="intellij.java.impl"/>
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <consoleFilterProvider implementation="com.intellij.java.terminal.backend.NoJavaExecutableFilter"/>
    <postStartupActivity implementation="com.intellij.java.terminal.backend.JavaTerminalSettingsReloadActivity"/>
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.plugins.terminal">
    <shellExecOptionsCustomizer implementation="com.intellij.java.terminal.backend.JdkCustomizer"/>
    <commandSpecsProvider implementation="com.intellij.java.terminal.backend.JavaShellCommandSpecsProvider"/>
    <commandSpecsProvider implementation="com.intellij.java.terminal.backend.JavacShellCommandSpecsProvider"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij.openapi.projectRoots">
    <externalJavaConfigurationMissingAction implementation="com.intellij.java.terminal.backend.ExternalJavaConfigurationDownloadInTerminalAction"/>
  </extensions>
</idea-plugin>
