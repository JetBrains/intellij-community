<idea-plugin>
  <dependencies>
    <plugin id="org.jetbrains.plugins.terminal"/>
    <module name="intellij.java.execution.impl"/>
    <module name="intellij.java.impl"/>

    <module name="intellij.platform.backend"/>
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <consoleFilterProvider implementation="com.intellij.java.terminal.NoJavaExecutableFilter"/>
    <postStartupActivity implementation="com.intellij.java.terminal.JavaTerminalSettingsReloadActivity"/>
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.plugins.terminal">
    <shellExecOptionsCustomizer implementation="com.intellij.java.terminal.JdkCustomizer"/>
    <commandSpecsProvider implementation="com.intellij.java.terminal.JavaShellCommandSpecsProvider"/>
    <commandSpecsProvider implementation="com.intellij.java.terminal.JavacShellCommandSpecsProvider"/>
    <terminalSettingsProvider implementation="com.intellij.java.terminal.JavaTerminalSettingsProvider"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij.openapi.projectRoots">
    <externalJavaConfigurationMissingAction implementation="com.intellij.java.terminal.ExternalJavaConfigurationDownloadInTerminalAction"/>
  </extensions>
</idea-plugin>
