<idea-plugin visibility="public">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.grid.types"/>
    <module name="intellij.libraries.automaton"/>
    <module name="intellij.libraries.kotlinx.collections.immutable"/>
    <module name="intellij.platform.core"/>
    <module name="intellij.platform.core.impl"/>
    <module name="intellij.platform.projectModel"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.intellij.database.settings.CsvSettings"/>
    <fileType name="CSV/TSV" implementationClass="com.intellij.database.csv.CsvFileType" fieldName="INSTANCE" extensions="csv;tsv"/>
  </extensions>
</idea-plugin>