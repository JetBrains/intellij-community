<!--
In Android Studio, this file is loaded *instead* of IdeaPlugin.xml.
If a plugin wants to perform Android-Studio-specific customizations, then it can add an
optional dependency on the module 'com.intellij.modules.androidstudio' declared below.
-->
<idea-plugin xmlns:xi="http://www.w3.org/2001/XInclude">
  <module value="com.intellij.modules.androidstudio"/>
  <module value="com.intellij.modules.cidr.ide"/>
  <!-- We bundle 'com.intellij.modules.nativeDebug' instead of its commercial variant 'com.intellij.nativeDebug' (CPP-33729). -->
  <incompatible-with>com.intellij.nativeDebug</incompatible-with>
  <!-- The following content is loosely based on IdeaPlugin.xml. -->
  <xi:include href="/META-INF/JavaIdePlugin.xml"/>
  <module value="com.intellij.modules.java-capable"/>
  <module value="com.intellij.modules.python-core-capable"/> <!-- Python plugin can be installed -->
  <module value="com.intellij.modules.python-in-non-pycharm-ide-capable"/> <!-- Enable Non-Pycharm-IDE support in Python plugin -->
  <content>
    <module name="intellij.platform.coverage"/>
    <module name="intellij.platform.coverage.agent"/>
    <module name="intellij.settingsSync.core"/>
    <!-- From CLionPlugin.xml: -->
    <module name="intellij.rml.dfa.impl"/>
    <!-- GRPC is normally only included in IntelliJ Ultimate, but we need it for the Android plugin. -->
    <module name="intellij.libraries.grpc"/>
    <module name="intellij.libraries.grpc.netty.shaded"/>
  </content>
  <xi:include href="/META-INF/common-ide-modules.xml"/>
</idea-plugin>
