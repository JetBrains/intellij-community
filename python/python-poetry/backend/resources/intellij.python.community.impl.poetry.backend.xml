<idea-plugin visibility="internal">
  <dependencies>
    <module name="intellij.python.sdk"/>
    <module name="intellij.platform.backend"/>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.python.community"/>
    <module name="intellij.python.community.common"/>
    <module name="intellij.python.community.impl.poetry.common"/>
    <module name="intellij.python.pyproject"/>
    <!-- endregion -->
  </dependencies>
  <extensions defaultExtensionNs="Pythonid">
    <pySdkProvider implementation="com.intellij.python.community.impl.poetry.backend.sdk.PoetrySdkProvider"/>
    <pythonFlavorProvider implementation="com.jetbrains.python.sdk.poetry.PyPoetrySdkFlavorProvider"/>
  </extensions>
  <extensions defaultExtensionNs="com.intellij.python.pyproject.model">
    <pyprojectmanager implementation="com.intellij.python.community.impl.poetry.backend.PoetryPyProjectManager"/>
  </extensions>
</idea-plugin>