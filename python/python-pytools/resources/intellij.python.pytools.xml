<idea-plugin visibility="public">
  <dependencies>
    <module name="intellij.python.community"/>
    <module name="intellij.python.community.execService"/>
    <module name="intellij.python.sdk"/>
  </dependencies>

  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.python.pytools.pyTool"
                    interface="com.intellij.python.pytools.PyTool"
                    dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <statistics.counterUsagesCollector implementationClass="com.intellij.python.pytools.statistics.PyToolUsagesCollector"/>
  </extensions>
</idea-plugin>
