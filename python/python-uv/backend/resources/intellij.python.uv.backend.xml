<idea-plugin visibility="public">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.python.sdk"/>
    <module name="intellij.platform.backend"/>
    <module name="intellij.python.community"/>
    <module name="intellij.python.community.common"/>
    <module name="intellij.python.community.execService"/>
    <module name="intellij.python.pyproject"/>
    <module name="intellij.python.pytools"/>
    <module name="intellij.python.uv.common"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="Pythonid">
    <!-- Uv -->
    <pythonFlavorProvider implementation="com.jetbrains.python.sdk.uv.UvSdkFlavorProvider"/>
  </extensions>
  <extensions defaultExtensionNs="com.intellij.python.pyproject.model">
    <pyprojectmanager implementation="com.intellij.python.uv.backend.UvPyProjectManager"/>
  </extensions>
</idea-plugin>
