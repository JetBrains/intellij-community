<idea-plugin visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.python.community.execService"/>
    <module name="intellij.python.community.impl"/>
    <module name="intellij.python.pytools"/>
    <module name="intellij.python.pytools.ui"/>
  </dependencies>
  <!-- endregion -->
  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.python.lsp.typeEngineConfigurable"
                    interface="com.intellij.python.lsp.core.typeEngine.PyTypeEngineProvider"
                    dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.python.lsp.notebookLanguageResolver"
                    interface="com.intellij.python.lsp.core.NotebookLanguageResolver"
                    dynamic="true"/>
  </extensionPoints>
  <extensions defaultExtensionNs="com.intellij">
    <python.lsp.typeEngineConfigurable implementation="com.intellij.python.lsp.core.typeEngine.BuiltInPyTypeEngineProvider"/>

    <statistics.counterUsagesCollector implementationClass="com.intellij.python.lsp.core.typeEngine.PyTypeEngineUsageCollector"/>
    <projectSettings service="com.intellij.python.lsp.core.typeEngine.PyTypeEngineProjectSettings"/>
    <notificationGroup id="Python LSP Tools" displayType="STICKY_BALLOON" isLogByDefault="true" bundle="messages.PyBundle"
                       key="notification.group.python.lsp.tools"/>
  </extensions>
</idea-plugin>