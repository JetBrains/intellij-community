<idea-plugin>
  <dependencies>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.python.community.common"/>
    <module name="intellij.python.community"/>
    <module name="intellij.python.community.execService"/>
    <module name="intellij.python.community.execService.python"/>
    <module name="intellij.python.processOutput.common"/>
    <module name="intellij.python.pyproject"/>
    <module name="intellij.python.pytools"/>
    <module name="intellij.python.sdk"/>
    <module name="intellij.python.sdk.ui"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="Pythonid">
    <evoTreeElementProvider id="HatchEvoProvider"
                            order="after CondaEvoProvider"
                            implementation="com.intellij.python.hatch.sdk.evolution.HatchSelectSdkProvider"/>

    <pySdkProvider implementation="com.intellij.python.hatch.impl.sdk.HatchSdkProvider"/>
    <pythonFlavorProvider implementation="com.intellij.python.hatch.impl.sdk.HatchSdkFlavorProvider"/>
  </extensions>
  <extensions defaultExtensionNs="com.intellij">
    <python.pytools.pyTool implementation="com.intellij.python.hatch.HatchPyTool"/>
    <python.community.common.toolToIconMapper implementation="com.intellij.python.hatch.impl.HatchIdMapper"/>
    <python.processOutput.common.processOutputIconMapping implementation="com.intellij.python.hatch.impl.HatchIconMapping"/>
  </extensions>
</idea-plugin>