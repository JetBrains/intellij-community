Subject: [PATCH] Support MSVC with rule-based toolchain
---
Index: .bazelci/presubmit.yml
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/.bazelci/presubmit.yml b/.bazelci/presubmit.yml
--- a/.bazelci/presubmit.yml	(revision 0850152bab13d8ec609631452e905df46c1495e7)
+++ b/.bazelci/presubmit.yml	(revision 59b791d06ac059e1801b95b2595814dceccb33c3)
@@ -295,3 +295,17 @@
       - "--enable_bzlmod"
     build_targets:
       - "//..."
+
+  windows_rule_based_toolchains:
+    name: Windows rule-based toolchains (msvc-cl)
+    platform: windows
+    working_directory: examples/rule_based_toolchain
+    build_flags:
+      - "--enable_bzlmod"
+      - "--config=msvc-cl"
+    build_targets:
+      - "//..."
+    test_flags:
+      - "--config=msvc-cl"
+    test_targets:
+      - "//..."
