# backend_config.bzl
# Materializes @ij_backend_config//:defs.bzl with the loading-phase constant
# USE_RULES_KOTLIN_BACKEND, driven by the IJ_JVM_USE_RULES_KOTLIN_BACKEND env var.
#
#   unset / 0 / false -> JPS: native rules_jvm (_jvm_library_jps / _resourcegroup_jps). DEFAULT.
#   1 / true          -> BTA: rules_kotlin fork (kt_jvm_library).
#
# Switch to BTA via:  bazel build --repo_env=IJ_JVM_USE_RULES_KOTLIN_BACKEND=1 //...
#                     (or the --config=jps / --config=bta shortcuts in .bazelrc).

_ENV_VAR = "IJ_JVM_USE_RULES_KOTLIN_BACKEND"
_DEFAULT_USE_RULES_KOTLIN_BACKEND = False

_TRUE = ("1", "true", "yes", "on")
_FALSE = ("0", "false", "no", "off")

def _parse_bool(raw, default):
    v = raw.strip().lower()
    if v == "":
        return default
    if v in _TRUE:
        return True
    if v in _FALSE:
        return False
    fail("{env}: expected one of {t} / {f}, got {got}".format(
        env = _ENV_VAR,
        t = "/".join(_TRUE),
        f = "/".join(_FALSE),
        got = repr(raw),
    ))

def _backend_config_repo_impl(rctx):
    use_rk = _parse_bool(rctx.getenv(_ENV_VAR, ""), _DEFAULT_USE_RULES_KOTLIN_BACKEND)
    rctx.file(
        "defs.bzl",
        "# @generated by backend_config.bzl from {env} (empty => default {d}).\n".format(
            env = _ENV_VAR,
            d = _DEFAULT_USE_RULES_KOTLIN_BACKEND,
        ) + "USE_RULES_KOTLIN_BACKEND = {}\n".format(use_rk),
    )
    rctx.file("BUILD.bazel", "")
    return rctx.repo_metadata(reproducible = True)

backend_config_repo = repository_rule(
    implementation = _backend_config_repo_impl,
    environ = [_ENV_VAR],
)
