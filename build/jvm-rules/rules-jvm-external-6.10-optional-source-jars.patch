+def _merge_source_javadoc_entries(main_tree, extras_tree):
+    # Keep the strictly fetched main tree; append only source/javadoc
+    # classified dependencies discovered by the lenient second fetch.
+    # Skip entries without a resolved file - including those would cause
+    # the lock-file converter to record a synthetic `jar: null` shasum for
+    # POM-only coordinates whose javadoc/source was requested but missing,
+    # which in turn breaks BUILD file generation.
+    extras = []
+    for dep in extras_tree.get("dependencies", []):
+        if get_classifier(dep.get("coord", "")) not in ("sources", "javadoc"):
+            continue
+        if not dep.get("file", None):
+            continue
+        extras.append(dep)
+    merged = dict(main_tree)
+    merged["dependencies"] = list(main_tree.get("dependencies", [])) + extras
+    return merged
 
