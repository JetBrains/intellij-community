import static groovy.xml.NamespaceBuilder.newInstance as namespace
import static org.jetbrains.jps.idea.IdeaProjectLoader.guessHome

includeTargets << new File("${guessHome(this)}/build/scripts/utils.gant")
includeTargets << new File("${guessHome(this)}/build/scripts/cucumber-tests.gant")

requireProperty("out", "$home/out")

target(compile: "Compile project") {
  ant.delete(failonerror: false) {
    fileset(dir: "$home/reports")
    fileset(dir: "$home/bin", includes: "*.hprof")
  }

  loadProject()
  prepareOutputFolder()

  if (!isDefined("avoid.project.rebuild")) {
    clearBuildCaches()
    projectBuilder.cleanOutput()
    projectBuilder.buildAll()
    pruneTestPlugins()
  }
}

private pass(List<String> args, String prop) {
  if (isDefined(prop)) {
    args << "-D$prop=${p(prop)}"
  }
}

ant.taskdef(uri: "antlib:org.jacoco.ant", classpath: "${home}/plugins/coverage/lib/jacocoant.jar")
def jacoco = namespace(ant, "antlib:org.jacoco.ant")
def exec_data_file = "${out}/coverage/jacoco.exec"
def class_dump_dir = "${out}/coverage/classes"

target("enable_coverage": "Enable coverage measurement") {
  jacoco.agent(
    property: "jacoco_agent",
    destfile: exec_data_file,
    classdumpdir: class_dump_dir,
    // does not exactly duplicate test.patterns property
    includes: "org.jetbrains.android.*:com.android.tools.idea.*:"
            + "com.android.tools.ndk.*:com.google.gct.*",
    excludes: "*Test:*Test\$*:*TestCase:*TestCase\$*:*\$\$EnhancerBy*:"
            + "org.jetbrains.android.maven.*:org.jetbrains.android.compiler.*",
  )
}

target('run_tests': 'Run java tests') {
  depends([compile])

  def classpathFile = "$home/junit.classpath"
  //todo[nik] currently runtime classpath includes path to JDKs from all modules in it so we need to manually exclude paths from JDK 1.6
  Set<String> testRuntimeClasspath = removeJdkJarFiles(projectBuilder.moduleRuntimeClasspath(findModule("community-main-tests"), true))
  testRuntimeClasspath << "${jdk8Home}/lib/tools.jar"
  projectBuilder.info("Test runtime classpath=" + testRuntimeClasspath)
  new File(classpathFile).text = testRuntimeClasspath.findAll({ new File((String)it).exists() }).join('\n')

  List<String> bootstrapClasspath = removeJdkJarFiles(projectBuilder.moduleRuntimeClasspath(findModule("tests_bootstrap"), false))
  bootstrapClasspath << "${jdk8Home}/lib/tools.jar"
  projectBuilder.info("Bootstrap classpath=" + bootstrapClasspath)

  testcases.each { testCase ->
    List<String> jvmArgs = [
      "-Dclasspath.file=${classpathFile}",
      "-Didea.platform.prefix=AndroidStudio",
      "-Dbootstrap.testcases=$testCase"
    ]

    [
      "idea.test.group",
      "idea.test.patterns",
      "idea.fast.only",
      "idea.coverage.enabled.build",
      "teamcity.tests.recentlyFailedTests.file"
    ].each { pass(jvmArgs, it) }

    def tempDir = p("teamcity.build.tempDir", p("java.io.tmpdir"))
    jvmArgs << "-Dteamcity.build.tempDir=${tempDir}"

    System.getProperties().entrySet().each {
      if (it.key.startsWith("pass.")) {
        def trimmed = it.key.substring("pass.".length());
        jvmArgs << "-D${trimmed}=${it.value}"
      };
    }
    jvmArgs.addAll(commonJvmArgsForTests())
    if (isDefined("jvm_args")) {
      jvmArgs.addAll(jvm_args)
    }

    if (isDefined("jacoco_agent")) {
      jvmArgs << jacoco_agent
    }

    projectBuilder.info("Starting JUnit $testCase, JVM options: $jvmArgs")
    ant.junit(fork: "yes", showoutput: "true", logfailedtests: false) {
      jvmArgs.each {
        jvmarg(value: it)
      }

      classpath {
        bootstrapClasspath.each {
          pathelement(location: it)
        }
      }

      formatter(type: 'xml')
      test(name: 'com.intellij.tests.BootstrapTests')
    }
  }
}

target("coverage_report": "Generate coverage report") {
  jacoco.report() {
    executiondata() {
      file(file: exec_data_file)
    }
    structure(name: "Android Studio") {
      classfiles() {
        fileset(dir: class_dump_dir)
      }
      sourcefiles() {
        // cobbled together haphazardly, but sources aren't really needed anyway
        fileset(dir: "${home}/../adt/idea/common/src")
        fileset(dir: "${home}/../adt/idea/android/src")
        fileset(dir: "${home}/../adt/idea/designer/src")
        fileset(dir: "${home}/../adt/idea/sdk-updates/src")
        fileset(dir: "${home}/../studio/google/appindexing/src")
        fileset(dir: "${home}/../studio/google/cloud/testing/firebase-testing/src")
        fileset(dir: "${home}/../studio/google/cloud/tools/android-studio-plugin/src")
        fileset(dir: "${home}/../studio/google/cloud/tools/core-plugin/src")
        fileset(dir: "${home}/../studio/google/cloud/tools/core-plugin/src")
        fileset(dir: "${home}/../studio/google/cloud/tools/google-login-plugin/src")
        fileset(dir: "${home}/../studio/google/login/src")
        fileset(dir: "${home}/../vendor/google/android-ndk/src/")
      }
    }
    csv(destfile: "${out}/coverage/report.csv")
    xml(destfile: "${out}/coverage/report.xml")
    html(destdir: "${out}/coverage/report")
  }
}

target("coverage" : "Measure test coverage") {
  depends([compile, enable_coverage, run_tests, coverage_report])
}

target('default' : "Run all tests") {
  depends([compile, run_tests, run_cucumber_tests])
}
