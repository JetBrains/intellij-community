<idea-plugin implementation-detail="true">
  <id>intellij.libraries.misc.plugin</id>
  <name>Library Modules: Misc</name>
  <description>Provides miscellaneous library content modules for IntelliJ-based IDEs.</description>
  <vendor>JetBrains</vendor>
  <content namespace="jetbrains">
    <module name="intellij.libraries.javax.activation"/>
    <module name="intellij.libraries.opencsv"/>
    <module name="intellij.libraries.lucene.common"/>
    <module name="intellij.libraries.jettison"/>
    <module name="intellij.libraries.xstream"/>
    <module name="intellij.libraries.commons.text" loading="required"/>
  </content>
</idea-plugin>
